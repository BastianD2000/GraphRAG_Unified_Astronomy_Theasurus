<http://astrothesaurus.org/uat/971> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T18:51:34.879Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
