	skos:broader <http://astrothesaurus.org/uat/121> ;
	skos:prefLabel "Automatic patrol telescopes"@en .

<http://astrothesaurus.org/uat/1210> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:24:45.569Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
