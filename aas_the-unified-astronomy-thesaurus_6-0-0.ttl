<http://astrothesaurus.org/uat/116> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-11T18:31:08.727Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
