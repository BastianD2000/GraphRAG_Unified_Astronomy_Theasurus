<http://astrothesaurus.org/uat/1254> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2022-06-21T17:43:27.480Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Circumplanetary dust"@en , "Circumplanetary matter"@en , "Circumplanetary medium"@en ;
	skos:broader <http://astrothesaurus.org/uat/1528> ;
	skos:prefLabel "Planetary rings"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1253> , <http://astrothesaurus.org/uat/1451> , <http://astrothesaurus.org/uat/1562> , <http://astrothesaurus.org/uat/45> , <http://astrothesaurus.org/uat/2295> ;
	skos:related <http://astrothesaurus.org/uat/494> .

<http://astrothesaurus.org/uat/1451> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T14:49:41.853Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Shepherd moons"@en ;
	skos:broader <http://astrothesaurus.org/uat/1254> ;
	skos:prefLabel "Shepherd satellites"@en ;
	skos:definition "A natural satellite in orbit near the edge of a planetary ring, whose gravitational force on the ring particles strongly controls the distribution of material within the ring, creating ringlets and density waves within the ring and sharp edges at ring boundaries. Examples include Saturn's Prometheus and Pandora, which shepherd the narrow outer F ring and the Uranus satellites Cordelia and Ophelia and the epsilon ring. The faster-moving inside satellite accelerates the inner ring particles as it passes them, causing them to spiral out to larger orbits. At the same time the slower-moving outer satellite decelerates the outer ring particles as they pass by, causing them to spiral inward. The result is a narrow, well-defined ring."@en .

<http://astrothesaurus.org/uat/1562> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T16:32:30.120Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1254> ;
	skos:prefLabel "Spokes"@en ;
	skos:definition "In Saturn's rings, changing structures in the radial direction. It is thought that gravitational forces alone cannot account for the spoke structure, and it has been proposed that electrostatic repulsion between ring particles may play a role."@en .

<http://astrothesaurus.org/uat/45> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-26T18:42:01.843Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Ansa"@en ;
	skos:broader <http://astrothesaurus.org/uat/1254> ;
	skos:prefLabel "Ansae"@en ;
	skos:definition "The 'handles,' or extremities, of planetary rings, especially Saturn's, as viewed from Earth. "@en .

