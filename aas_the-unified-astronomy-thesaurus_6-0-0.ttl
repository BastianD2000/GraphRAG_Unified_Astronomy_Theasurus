<http://astrothesaurus.org/uat/1082> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T19:37:33.981Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
