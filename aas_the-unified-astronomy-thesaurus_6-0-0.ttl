<http://astrothesaurus.org/uat/425> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:46:28.061Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
