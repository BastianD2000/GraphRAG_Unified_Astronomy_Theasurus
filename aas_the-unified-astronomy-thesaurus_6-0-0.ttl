	skos:broader <http://astrothesaurus.org/uat/1528> ;
	skos:prefLabel "Natural satellites (Solar system)"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2027> , <http://astrothesaurus.org/uat/1009> , <http://astrothesaurus.org/uat/1098> , <http://astrothesaurus.org/uat/1427> , <http://astrothesaurus.org/uat/1692> , <http://astrothesaurus.org/uat/1750> , <http://astrothesaurus.org/uat/872> , <http://astrothesaurus.org/uat/2202> , <http://astrothesaurus.org/uat/2207> ;
	skos:related <http://astrothesaurus.org/uat/1260> , <http://astrothesaurus.org/uat/1425> , <http://astrothesaurus.org/uat/483> , <http://astrothesaurus.org/uat/2208> , <http://astrothesaurus.org/uat/2212> , <http://astrothesaurus.org/uat/2214> ;
	skos:definition "A solar system object that revolves around a primary body and is not man made."@en .

<http://astrothesaurus.org/uat/819> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/101> ;
	skos:prefLabel "Internal waves"@en .

<http://astrothesaurus.org/uat/1010> a rdfs:Resource , skos:Concept ;
