<http://astrothesaurus.org/uat/1639> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-02T22:03:10.202Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Mesopeak"@en ;
	skos:broader <http://astrothesaurus.org/uat/437> ;
	skos:prefLabel "Stratopause"@en .

<http://astrothesaurus.org/uat/1640> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:21:50.413Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/437> ;
	skos:prefLabel "Stratosphere"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2409> ;
	skos:definition "The second major layer of Earth's atmosphere, just above the troposphere and below the mesosphere, extending from about 20 km to 90 km above the Earth. It is characterized by little vertical increase in temperature."@en .

<http://astrothesaurus.org/uat/1643> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:23:01.532Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/670> ;
	skos:prefLabel "Strong gravitational lensing"@en ;
	skos:definition "A gravitational lensing phenomenon in which the image distortion is strong enough to be readily recognized, such as in the case of the Einstein cross or when giant luminous arcs show up in galaxy clusters (e.g. Abell 2218).  Opposite to weak gravitational lensing."@en .

<http://astrothesaurus.org/uat/670> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T15:56:40.920Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Gravitational lens"@en ;
	skos:broader <http://astrothesaurus.org/uat/641> ;
	skos:prefLabel "Gravitational lensing"@en ;
	skos:narrower <http://astrothesaurus.org/uat/672> , <http://astrothesaurus.org/uat/1643> , <http://astrothesaurus.org/uat/1797> , <http://astrothesaurus.org/uat/451> , <http://astrothesaurus.org/uat/671> , <http://astrothesaurus.org/uat/2151> , <http://astrothesaurus.org/uat/2152> ;
	skos:definition "A concentration of matter, such as a galaxy or a cluster of galaxies, that bends light rays from a background object, resulting in production of multiple images. If the two objects and the Earth are perfectly aligned, the light from the distant object appears as a ring from Earth. This is called an Einstein Ring, since its existence was predicted by Einstein in his theory of general relativity."@en .

<http://astrothesaurus.org/uat/1644> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/226> , <http://astrothesaurus.org/uat/705> ;
	skos:prefLabel "Strontium stars"@en .

<http://astrothesaurus.org/uat/1645> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/418> ;
	skos:prefLabel "SU Ursae Majoris stars"@en .

<http://astrothesaurus.org/uat/481> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-30T19:39:27.494Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Post-main sequence stars"@en ;
	skos:broader <http://astrothesaurus.org/uat/2052> ;
	skos:prefLabel "Evolved stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1646> , <http://astrothesaurus.org/uat/655> , <http://astrothesaurus.org/uat/1661> , <http://astrothesaurus.org/uat/774> ;
	skos:related <http://astrothesaurus.org/uat/725> ;
	skos:definition "A star that has left the main sequence."@en .

<http://astrothesaurus.org/uat/1652> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:25:42.245Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Relative sunspot number"@en , "SSN"@en , "Wolf number"@en ;
	skos:broader <http://astrothesaurus.org/uat/1653> ;
	skos:prefLabel "Sunspot number"@en ;
	skos:definition "A quantity which gives the number of sunspots at a given time. It is defined by the relationship R = k(10g + f), where R is the sunspot number, k is a constant depending on the observation conditions and the instrument used, g is the number of the groups and f is the number of individual spots that can be counted."@en .

<http://astrothesaurus.org/uat/1803> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T17:05:24.953Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1653> ;
	skos:prefLabel "Wilson effect"@en ;
	skos:definition "A phenomenon in which the shape of sunspots flattens as they approach the Sun's limb due to the solar rotation. More specifically, when a sunspot approaches the solar limbs the width of the penumbra, relative to the umbra, on the side facing the center of the Sun seems to become narrower than on the side facing the limb. This phenomenon arises from a projection effect, and is due to a geometrical depression (the Wilson depression) in the layers of constant optical depth in sunspots."@en .

<http://astrothesaurus.org/uat/1655> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T18:53:34.215Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Super-Earths"@en ;
	skos:broader <http://astrothesaurus.org/uat/498> ;
	skos:prefLabel "Super Earths"@en ;
	skos:definition "An extrasolar planet more massive than the Earth but less massive than 10 Earth masses. The first discovered super-Earth orbits an M4 V star named GJ 876. Its estimated mass is 7.5±0.7 Earth masses and it has an orbital period of 1.94 days. It is close to the host star, and the surface temperature is calculated to lie between 430 and 650 K."@en .

<http://astrothesaurus.org/uat/1656> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T18:51:03.086Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/847> ;
	skos:prefLabel "Superbubbles"@en ;
	skos:definition "A cavity hundreds of light-years across filled with a hot gas blown into the interstellar medium by multiple supernovae and stellar winds. Examples are the Local Bubble in the Orion Arm of the Milky Way and the N44 Superbubble in the Large Magellanic Cloud."@en .

<http://astrothesaurus.org/uat/1657> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T18:52:27.103Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/584> ;
	skos:prefLabel "Superclusters"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1773> ;
	skos:definition "An aggregation of clusters of galaxies. Superclusters are typically about one hundred million (10^8) light-years in diameter and contain tens of thousands of galaxies. Some examples are the Local Supercluster, Centaurus supercluster, Laniakea supercluster, Perseus-Pisces supercluster, Shapley supercluster, Virgo supercluster. "@en .

<http://astrothesaurus.org/uat/1773> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:57:02.092Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Local Supercluster"@en , "Virgo SC"@en ;
	skos:broader <http://astrothesaurus.org/uat/1657> ;
	skos:prefLabel "Virgo Supercluster"@en ;
	skos:related <http://astrothesaurus.org/uat/1772> ;
	skos:definition "The irregular supercluster that contains the Virgo cluster and the Local Group. At least 100 galaxy groups and clusters are located within its diameter of 110 million light-years. It is one of millions of superclusters in the observable Universe."@en .

<http://astrothesaurus.org/uat/1658> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:27:39.780Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/82> ;
	skos:prefLabel "Supergalactic coordinate system"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1659> , <http://astrothesaurus.org/uat/1660> ;
	skos:definition "A spherical coordinate system in which the equator is the supergalactic plane. Supergalactic longitude, SGL, is measured counterclockwise from direction l = 137.37 deg, b = 0 deg (between 0 and 360 deg). The zero point for supergalactic longitude is defined by the intersection of this plane with the Galactic plane. In the equatorial coordinate system (J2000) this is approximately 2.82 h, +59.5 deg. Supergalactic latitude, SGB, is measured from the supergalactic plane, positive northward and negative southward. The North Supergalactic Pole (SGB=90 deg) lies at galactic coordinates l = 47.37 deg, b = +6.32 degrees, corresponding to the equatorial coordinate system (J2000) 18.9 h, +15.7 deg."@en .

<http://astrothesaurus.org/uat/82> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-26T18:50:05.412Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Celestial coordinate systems"@en , "Celestial reference system"@en ;
	skos:broader <http://astrothesaurus.org/uat/80> ;
	skos:prefLabel "Astronomical coordinate systems"@en ;
	skos:narrower <http://astrothesaurus.org/uat/747> , <http://astrothesaurus.org/uat/566> , <http://astrothesaurus.org/uat/467> , <http://astrothesaurus.org/uat/1658> , <http://astrothesaurus.org/uat/445> ;
	skos:definition "Values in a reference system used to relate the position of a body on the celestial sphere. Four main coordinate systems are utilized in astronomy: the equatorial, horizontal, ecliptic, and galactic coordinates systems."@en .

<http://astrothesaurus.org/uat/1659> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1658> ;
	skos:prefLabel "Supergalactic latitude"@en .

<http://astrothesaurus.org/uat/1660> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1658> ;
	skos:prefLabel "Supergalactic longitude"@en .

<http://astrothesaurus.org/uat/166> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/586> ;
	skos:prefLabel "Blue cloud galaxies"@en .

<http://astrothesaurus.org/uat/1666> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/96> ;
	skos:prefLabel "Supernova neutrinos"@en .

<http://astrothesaurus.org/uat/1728> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T21:47:16.570Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Type Ia supernova"@en ;
	skos:broader <http://astrothesaurus.org/uat/1668> ;
	skos:prefLabel "Type Ia supernovae"@en ;
	skos:related <http://astrothesaurus.org/uat/1799> ;
	skos:definition "A Type I supernova that presents a singly-ionized silicon (Si II) absorption feature at 6150 Å near peak brightness. Type Ia SNe are believed to result from mass accretion to a carbon-oxygen white dwarf in a close binary system. When the white dwarf mass exceeds the Chandrasekhar limit, the degenerate electron pressure can no longer support the accumulated mass and the star collapses in a thermonuclear explosion producing a supernova. The peak luminosity of SNe Ia is set by the radioactive decay chain, and the observed photometric correlation between the peak luminosity and the time-scale over which the light curve decays from its maximum is understood physically as having both the luminosity and opacity being set by the mass of Nickel-56 synthesized in the explosion. Type Ia supernovae occur in all types of galaxies. Type Ia SNe are used as standard candles in determining cosmological distances, after normalizing their light curves with the Phillips relation."@en .

<http://astrothesaurus.org/uat/304> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-05T20:32:02.882Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Core collapse supernova"@en , "Core collapse supernovae"@en , "Core-collapse supernova"@en ;
	skos:broader <http://astrothesaurus.org/uat/1668> ;
	skos:prefLabel "Core-collapse supernovae"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1729> , <http://astrothesaurus.org/uat/1730> , <http://astrothesaurus.org/uat/1731> ;
	skos:definition "A supernova arising from the core collapse of a massive star."@en .

<http://astrothesaurus.org/uat/775> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-02T19:21:57.087Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Hypernova"@en ;
	skos:broader <http://astrothesaurus.org/uat/1668> ;
	skos:prefLabel "Hypernovae"@en ;
	skos:definition "A highly energetic supernova explosion. This phenomenon, which is more violent than a typical supernova event, is accompanied by a gamma-ray burst."@en .

<http://astrothesaurus.org/uat/167> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T17:47:32.056Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/725> ;
	skos:prefLabel "Blue loop"@en ;
	skos:definition "An evolutionary behavior of certain stars, particularly massive stars, which return to the blue stage after becoming a red supergiant. The phenomenon appears as a blueward loop on the theoretical evolutionary tracks."@en .

