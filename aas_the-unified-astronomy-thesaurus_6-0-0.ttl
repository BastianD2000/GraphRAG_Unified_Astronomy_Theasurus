	skos:prefLabel "Solar-planetary interactions"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1246> , <http://astrothesaurus.org/uat/1473> , <http://astrothesaurus.org/uat/997> , <http://astrothesaurus.org/uat/2185> ;
