<http://astrothesaurus.org/uat/397> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T21:15:28.753Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
