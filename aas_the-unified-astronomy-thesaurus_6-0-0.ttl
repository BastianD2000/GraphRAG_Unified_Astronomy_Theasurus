	skos:narrower <http://astrothesaurus.org/uat/1005> , <http://astrothesaurus.org/uat/1143> , <http://astrothesaurus.org/uat/1247> , <http://astrothesaurus.org/uat/1248> , <http://astrothesaurus.org/uat/1251> , <http://astrothesaurus.org/uat/1273> , <http://astrothesaurus.org/uat/1780> , <http://astrothesaurus.org/uat/770> , <http://astrothesaurus.org/uat/928> , <http://astrothesaurus.org/uat/2113> , <http://astrothesaurus.org/uat/2288> , <http://astrothesaurus.org/uat/2303> ;
	skos:related <http://astrothesaurus.org/uat/495> ;
	skos:scopeNote "Refers to planets in our Solar system."@en .

<http://astrothesaurus.org/uat/1006> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/17> , <http://astrothesaurus.org/uat/459> ;
	skos:prefLabel "Markarian galaxies"@en .

<http://astrothesaurus.org/uat/17> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T17:54:29.591Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/573> ;
	skos:prefLabel "Active galaxies"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2017> , <http://astrothesaurus.org/uat/1006> , <http://astrothesaurus.org/uat/16> , <http://astrothesaurus.org/uat/1343> , <http://astrothesaurus.org/uat/1570> , <http://astrothesaurus.org/uat/158> , <http://astrothesaurus.org/uat/164> , <http://astrothesaurus.org/uat/701> , <http://astrothesaurus.org/uat/925> ;
	skos:definition "A galaxy that produces huge amounts of energy at its center, which cannot be attributed to normal processes from stars, interstellar medium, and their interactions. There are several types of active galaxies: Seyfert galaxies, quasars, and blazars. All of these objects show brightness variations, some as short as 3 hours. These fluctuations indicate a relatively very small size for the central object, because an object cannot vary in brightness faster than light can travel across it. For example, an object that is one light-year in diameter cannot vary significantly in brightness over a period of less than one year."@en .

<http://astrothesaurus.org/uat/459> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/573> ;
	skos:prefLabel "Emission line galaxies"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1006> , <http://astrothesaurus.org/uat/1447> , <http://astrothesaurus.org/uat/925> .

<http://astrothesaurus.org/uat/1007> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T17:16:58.160Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/797> ;
	skos:prefLabel "Mars"@en ;
	skos:related <http://astrothesaurus.org/uat/1009> ;
	skos:definition "Fourth planet from Sun and the seventh largest. Mass 6.42 x 10^26 g (0.11 Earth's); radius 3397 km. Mean distance from Sun 1.52 AU. Sidereal period 687 days; synodic period 779.9 days. Surface temperature 248 K., rotational period 24h 37m 22.66s. Obliquity 23°59'. Atmosphere more than 90% CO_2, traces of O_2, CO, H_{2}O. Two tiny satellites (Phobos and Deimos), both of which are locked in synchronous rotation with Mars."@en .

<http://astrothesaurus.org/uat/797> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T21:34:23.823Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Terrestrial planet"@en , "Terrestrial planets"@en , "Inner planets"@en ;
	skos:broader <http://astrothesaurus.org/uat/1260> ;
	skos:prefLabel "Solar system terrestrial planets"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1007> , <http://astrothesaurus.org/uat/1024> , <http://astrothesaurus.org/uat/1763> , <http://astrothesaurus.org/uat/439> ;
	skos:related <http://astrothesaurus.org/uat/511> ;
	skos:definition "The planets Mercury, Venus, Earth and Mars collectively. They are also known as the terrestrial planets."@en .

<http://astrothesaurus.org/uat/1008> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T19:17:35.491Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1715> ;
	skos:prefLabel "Mars trojans"@en ;
	skos:definition "The family of asteroids located at either of the stable Lagrangian points (L4 or L5) of the orbit of Mars."@en .

<http://astrothesaurus.org/uat/1715> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T21:57:14.012Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Trojan group"@en , "Trojans"@en ;
	skos:broader <http://astrothesaurus.org/uat/72> ;
	skos:prefLabel "Trojan asteroids"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1008> , <http://astrothesaurus.org/uat/438> , <http://astrothesaurus.org/uat/1097> , <http://astrothesaurus.org/uat/874> ;
	skos:definition "A member of the family of asteroids that share Jupiter's orbit and lie in elongated, curved regions around the two Lagrangian points 60° ahead and behind of Jupiter. The Lagrangian points L4 and L5 host several thousands of them. Originally, the term Trojan applied only to asteroids sharing Jupiter's orbit; however, planetoidal bodies have been discovered at the Lagrangian points of Mars and Neptune as well, and are also referred to as Mars Trojans and Neptune Trojans respectively."@en .

<http://astrothesaurus.org/uat/1009> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-09T15:23:39.718Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Deimos"@en , "Martian moons"@en , "Moons of Mars"@en , "Phobos"@en ;
	skos:broader <http://astrothesaurus.org/uat/1089> ;
	skos:prefLabel "Martian satellites"@en ;
	skos:related <http://astrothesaurus.org/uat/1007> ;
	skos:example "Deimos"@en , "Phobos"@en .

<http://astrothesaurus.org/uat/1089> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2022-06-21T17:44:41.762Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
