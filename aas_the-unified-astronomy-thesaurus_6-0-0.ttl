	skos:prefLabel "Spectrometers"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1013> ;
	skos:definition "A spectrograph in which the spectrum is recorded by electronic means so that wavelength, intensity, etc. can be measured.  An instrument for determining the distribution of energies in a beam of particles."@en .

