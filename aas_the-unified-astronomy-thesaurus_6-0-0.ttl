	skos:definition "An astronomical object that emits gamma rays."@en .

<http://astrothesaurus.org/uat/1473> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2025-12-16T19:25:52.170Z"^^xsd:dateTime ;
