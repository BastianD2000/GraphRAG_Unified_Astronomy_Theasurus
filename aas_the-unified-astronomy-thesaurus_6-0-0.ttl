<http://astrothesaurus.org/uat/1695> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:37:16.341Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Three body problem"@en ;
	skos:broader <http://astrothesaurus.org/uat/211> , <http://astrothesaurus.org/uat/669> ;
	skos:prefLabel "Three-body problem"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1012> , <http://astrothesaurus.org/uat/1404> , <http://astrothesaurus.org/uat/1405> , <http://astrothesaurus.org/uat/897> ;
	skos:definition "The mathematical problem of studying the positions and velocities of three mutually attracting bodies (such as the Sun, Earth and Moon) and the stability of their motion. This problem is surprisingly difficult to solve, even in the simple case, called restricted three-body problem, where one of the masses is taken to be negligibly small so that the problem simplifies to finding the behavior of the mass-less body in the combined gravitational field of the other two."@en .

<http://astrothesaurus.org/uat/1554> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T17:22:21.016Z"^^xsd:dateTime ;
