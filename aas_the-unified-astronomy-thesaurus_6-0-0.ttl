	dcterms:modified "2020-12-16T20:25:49.948Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Classical Kuiper-belt objects"@en , "Cubewanos"@en , "cubewanos"@en ;
