	skos:broader <http://astrothesaurus.org/uat/859> ;
	skos:prefLabel "Pulsating variable stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2101> , <http://astrothesaurus.org/uat/1311> , <http://astrothesaurus.org/uat/369> , <http://astrothesaurus.org/uat/1079> , <http://astrothesaurus.org/uat/1066> , <http://astrothesaurus.org/uat/935> , <http://astrothesaurus.org/uat/148> , <http://astrothesaurus.org/uat/370> , <http://astrothesaurus.org/uat/404> , <http://astrothesaurus.org/uat/2> , <http://astrothesaurus.org/uat/218> , <http://astrothesaurus.org/uat/865> , <http://astrothesaurus.org/uat/899> , <http://astrothesaurus.org/uat/1410> , <http://astrothesaurus.org/uat/2112> , <http://astrothesaurus.org/uat/2122> ;
	skos:definition "A type of variable star that changes its brightness by changing its volume through expansion and contraction. Classical pulsating stars, including Cepheids, RR Lyrae, and Delta Scuti variables, are located in a quite narrow almost vertical region in the H-R diagram, known as instability strip."@en .

<http://astrothesaurus.org/uat/935> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T15:40:11.325Z"^^xsd:dateTime ;
