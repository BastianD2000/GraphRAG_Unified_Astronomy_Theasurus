	skos:prefLabel "Long period variable stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1466> , <http://astrothesaurus.org/uat/1066> , <http://astrothesaurus.org/uat/1444> , <http://astrothesaurus.org/uat/2123> ;
	skos:definition "A type of variable star in which variations in brightness occur over long time-scales of months or years. The term generally refers to Mira variable types."@en .

<http://astrothesaurus.org/uat/1068> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T19:36:44.485Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/813> ;
	skos:prefLabel "Missing mass"@en ;
	skos:definition "The unseen mass whose gravitational influence is needed to account for the way galaxies rotate, and also to bind clusters of galaxies together. It is thought to consist, in part, of giant halos of dark matter that surround the visible portions of galaxies, and similar material that invisibly occupies the intergalactic voids."@en .

