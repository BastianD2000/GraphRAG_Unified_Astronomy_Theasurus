<http://astrothesaurus.org/uat/1690> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:34:10.323Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
