	skos:prefLabel "Neutrino astronomy"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1102> , <http://astrothesaurus.org/uat/1510> , <http://astrothesaurus.org/uat/1752> .

<http://astrothesaurus.org/uat/1146> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:01:23.031Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/343> , <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Observational cosmology"@en ;
	skos:narrower <http://astrothesaurus.org/uat/334> , <http://astrothesaurus.org/uat/758> ;
	skos:definition "The application of observational data to the study of the Universe as a whole."@en .

<http://astrothesaurus.org/uat/1329> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2024-06-20T12:30:07.657Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Radar astronomy"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2287> ;
	skos:definition "Astronomy in which celestial bodies in the solar system are studied by analyzing the return of radio waves directed at them."@en .

<http://astrothesaurus.org/uat/1338> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2024-06-20T12:28:18.383Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Radio astronomy"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1654> , <http://astrothesaurus.org/uat/323> , <http://astrothesaurus.org/uat/1061> , <http://astrothesaurus.org/uat/1337> , <http://astrothesaurus.org/uat/1553> , <http://astrothesaurus.org/uat/1647> , <http://astrothesaurus.org/uat/182> , <http://astrothesaurus.org/uat/828> , <http://astrothesaurus.org/uat/855> ;
	skos:related <http://astrothesaurus.org/uat/1358> , <http://astrothesaurus.org/uat/1359> ;
	skos:definition "The branch of astronomy that deals with the study of the Universe by means of radio waves. Radio waves are the electromagnetic radiation with the longest wavelengths (and lowest energies), ranging from 0.3 mm to several km. Radio waves form a very broad category, which includes the submillimeter waves (with a wavelengths of 0.3-1 mm) and microwave regions (1mm to several cm)."@en .

<http://astrothesaurus.org/uat/1736> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:49:13.943Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "UV astronomy"@en ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Ultraviolet astronomy"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1094> , <http://astrothesaurus.org/uat/2170> ;
	skos:related <http://astrothesaurus.org/uat/1741> ;
	skos:definition "The study of astronomical objects in the ultraviolet portions of the electromagnetic spectrum, in the waveband 3000 Å to about 10 Å. At these wavelengths, the atmosphere prevents ultraviolet radiation from reaching the Earth surface. Therefore ground-based observatories cannot observe in the ultraviolet. Only with the advent of space-based telescopes has this area of astronomy become available for research."@en .

<http://astrothesaurus.org/uat/1776> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2024-06-20T12:26:26.880Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Visible astronomical observations"@en , "Visible telescopes"@en , "Visible astronomy"@en ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Optical astronomy"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1167> ;
	skos:related <http://astrothesaurus.org/uat/2108> ;
	skos:definition "An area of astronomy where astronomers observe and analyse light from the Universe that falls within the wavelength range that the human eye is sensitive to, about 400 nm (violet) to 750 nm (red), which is also referred to as visible light."@en .

<http://astrothesaurus.org/uat/1810> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2024-06-20T13:12:03.020Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "X-ray galaxies"@en ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "X-ray astronomy"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1812> , <http://astrothesaurus.org/uat/1817> ;
	skos:related <http://astrothesaurus.org/uat/1822> ;
	skos:definition "The study of celestial bodies using their X-ray emission. X-ray astronomy deals mainly with Galactic and extragalactic phenomena involving very high-energy photon emissions, covering a band of energies between 0.1 keV and 500 keV. The research field includes: X-ray binaries, cataclysmic variables, pulsars, black holes, dark matter, active galaxies, galactic clusters X-ray transients. The Earth's atmosphere absorbs most X-rays coming from outer space. X-ray astronomy therefore requires observations to be done above atmosphere."@en .

<http://astrothesaurus.org/uat/324> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Cosmic ray astronomy"@en ;
	skos:related <http://astrothesaurus.org/uat/329> .

<http://astrothesaurus.org/uat/35> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-26T18:38:34.386Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Backyard astronomy"@en , "Stargazing"@en ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Amateur astronomy"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1113> , <http://astrothesaurus.org/uat/1310> ;
	skos:related <http://astrothesaurus.org/uat/34> ;
	skos:definition "The astronomical activities carried out by amateur astronomers."@en .

<http://astrothesaurus.org/uat/628> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2024-06-20T13:15:01.829Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Gamma astronomy"@en , "Gamma ray astronomical observations"@en , "Gamma ray astronomy"@en , "Gamma-ray astronomical observations"@en , "γ-ray astronomy"@en ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Gamma-ray astronomy"@en ;
	skos:related <http://astrothesaurus.org/uat/633> ;
	skos:definition "The study of gamma rays from extraterrestrial sources, especially gamma-ray bursts.  Gamma-rays are an electromagnetic wave with a typical wavelength less than 10-2Å (10-12 m), corresponding to frequencies above 1019 Hz and photon energies above 100 keV."@en .

<http://astrothesaurus.org/uat/675> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Gravitational wave astronomy"@en ;
	skos:related <http://astrothesaurus.org/uat/678> .

<http://astrothesaurus.org/uat/686> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T16:03:16.344Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Ground based astronomy"@en ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Ground-based astronomy"@en ;
	skos:definition "Astronomical study carried out using a telescope on Earth, as opposed to that from an orbiting satellite."@en .

<http://astrothesaurus.org/uat/786> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2024-06-20T12:21:09.636Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1043> ;
	skos:prefLabel "Infrared astronomy"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1093> , <http://astrothesaurus.org/uat/529> , <http://astrothesaurus.org/uat/788> ;
	skos:related <http://astrothesaurus.org/uat/793> ;
	skos:definition "The study of infrared properties of astronomical objects. Infrared is the invisible part of electromagnetic spectrum possessing wavelengths between those of visible light and those of radio waves, i.e. approximately between about 0.75 and 1000 μm."@en .

<http://astrothesaurus.org/uat/97> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T16:47:35.447Z"^^xsd:dateTime ;
