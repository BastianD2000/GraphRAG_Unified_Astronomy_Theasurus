<http://astrothesaurus.org/uat/92> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-05T15:23:48.696Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Dome seeing"@en ;
