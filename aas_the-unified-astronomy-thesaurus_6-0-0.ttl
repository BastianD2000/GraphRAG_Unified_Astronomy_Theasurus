<http://astrothesaurus.org/uat/836> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T17:46:06.676Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Cosmic dust"@en , "Dust grain"@en , "Dust grains"@en , "Interstellar dust clouds"@en , "Interstellar dust grains"@en , "Interstellar grains"@en ;
	skos:broader <http://astrothesaurus.org/uat/834> ;
	skos:prefLabel "Interstellar dust"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1280> , <http://astrothesaurus.org/uat/1456> , <http://astrothesaurus.org/uat/1770> , <http://astrothesaurus.org/uat/201> ;
	skos:related <http://astrothesaurus.org/uat/2090> , <http://astrothesaurus.org/uat/838> , <http://astrothesaurus.org/uat/837> ;
	skos:definition "An aggregation of dust grains in the space between stars. Interstellar dust absorbs, scatters, and polarizes the light from distant stars, causing the interstellar extinction. Large dark regions in the plane of the Milky Way and other galaxies are caused by intervening clouds of dust. The conclusive proof for the presence of a general and selective interstellar absorption is due to R. J. Trumpler (1930)."@en .

