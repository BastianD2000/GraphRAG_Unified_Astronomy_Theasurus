	skos:broader <http://astrothesaurus.org/uat/59> ;
	skos:prefLabel "Photovisual magnitude"@en ;
	skos:definition "Magnitude defined for the combination of a photographic plate and a yellow filter, approximating the spectral sensitivity of the eye."@en .

