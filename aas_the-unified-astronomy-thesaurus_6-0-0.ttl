	skos:prefLabel "Brightness temperature"@en ;
	skos:definition "In radio astronomy, the temperature of a source calculated on the assumption that it is a blackbody emitting radiation of the observed intensity at a given wavelength."@en .

<http://astrothesaurus.org/uat/828> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1338> , <http://astrothesaurus.org/uat/88> ;
	skos:prefLabel "Interplanetary scintillation"@en .

<http://astrothesaurus.org/uat/855> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T17:55:17.947Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1338> , <http://astrothesaurus.org/uat/88> ;
	skos:prefLabel "Interstellar scintillation"@en ;
	skos:definition "An apparent twinkling of the signals from distant point-like radio sources (pulsars). It is due to turbulence, i.e. fluctuations in the electron density of the interstellar ionized gas, through which the signals have passed on their way to Earth."@en .

<http://astrothesaurus.org/uat/1339> a rdfs:Resource , skos:Concept ;
