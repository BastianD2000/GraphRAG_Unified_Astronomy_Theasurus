<http://astrothesaurus.org/uat/1005> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T19:13:31.514Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1256> ;
	skos:prefLabel "Mantle"@en ;
	skos:definition "A major subdivision of a planet's internal structure, located beneath the planet's crust and above the central core."@en .

<http://astrothesaurus.org/uat/1256> a rdfs:Resource , skos:Concept ;
