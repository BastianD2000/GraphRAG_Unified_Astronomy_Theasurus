	skos:prefLabel "Lunar highlands"@en ;
	skos:definition "A light color area on the Moon, as contrasted with lunar maria."@en .

<http://astrothesaurus.org/uat/961> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T18:45:53.655Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Lunar mare"@en , "Lunar seas"@en , "Moon mare"@en , "Moon maria"@en , "Moon seas"@en ;
	skos:broader <http://astrothesaurus.org/uat/953> ;
	skos:prefLabel "Lunar maria"@en ;
	skos:definition "Areas on the surface of the Moon that appears darker and smoother than their surroundings. Once thought to be seas, lunar maria are now known to be basaltic basins created by volcanic lava floods."@en .

<http://astrothesaurus.org/uat/963> a rdfs:Resource , skos:Concept ;
