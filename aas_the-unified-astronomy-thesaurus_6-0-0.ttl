<http://astrothesaurus.org/uat/265> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T19:27:45.013Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/353> ;
	skos:prefLabel "Cold dark matter"@en ;
	skos:definition "Any hypothetical non-baryonic dark matter that is non-relativistic at the point of decoupling in the early Universe. CDM plays a key role in cosmic structure formation."@en .

<http://astrothesaurus.org/uat/266> a rdfs:Resource , skos:Concept ;
	skos:altLabel "CNM"@en ;
	skos:broader <http://astrothesaurus.org/uat/850> ;
