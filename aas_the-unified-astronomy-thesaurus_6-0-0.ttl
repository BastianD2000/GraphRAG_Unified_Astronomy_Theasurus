	skos:broader <http://astrothesaurus.org/uat/16> ;
	skos:prefLabel "Relativistic disks"@en .

<http://astrothesaurus.org/uat/1389> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1391> ;
	skos:prefLabel "Relativistic fluid dynamics"@en .

<http://astrothesaurus.org/uat/1391> a rdfs:Resource , skos:Concept ;
