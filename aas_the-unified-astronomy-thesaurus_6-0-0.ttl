<http://astrothesaurus.org/uat/124> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T18:37:16.027Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
