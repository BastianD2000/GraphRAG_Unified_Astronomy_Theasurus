	skos:prefLabel "Galaxy clusters"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2005> , <http://astrothesaurus.org/uat/2006> , <http://astrothesaurus.org/uat/2007> , <http://astrothesaurus.org/uat/1214> , <http://astrothesaurus.org/uat/141> , <http://astrothesaurus.org/uat/1657> , <http://astrothesaurus.org/uat/1772> , <http://astrothesaurus.org/uat/270> , <http://astrothesaurus.org/uat/858> , <http://astrothesaurus.org/uat/9> ;
	skos:definition "An aggregation of galaxies, made up of a few to a few thousand members, which may or may not be held together by its own gravity."@en .

