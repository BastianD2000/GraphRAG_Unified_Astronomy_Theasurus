<http://astrothesaurus.org/uat/1095> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2022-01-03T15:01:11.724Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
