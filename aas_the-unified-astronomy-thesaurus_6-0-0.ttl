<http://astrothesaurus.org/uat/682> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T15:58:53.317Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
