	skos:related <http://astrothesaurus.org/uat/1584> .

<http://astrothesaurus.org/uat/1492> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Evolution of the sun"@en ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "Solar evolution"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1508> ;
	skos:related <http://astrothesaurus.org/uat/1599> .

<http://astrothesaurus.org/uat/1494> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T15:49:06.334Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Solar facula"@en ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "Solar faculae"@en ;
	skos:related <http://astrothesaurus.org/uat/1601> ;
	skos:definition "A bright area of the photosphere of the Sun visible in white light and best seen near the solar limb, although they occur all across the Sun. Faculae raise several hundred kilometers above the photosphere and are associated with sunspots. They often appear immediately before the formation of a sunspot group and remain visible for several days or weeks after the disappearance of the spots. Faculae are formed when a strong magnetic field heats a region of the photosphere to higher temperatures than the surrounding area."@en .

<http://astrothesaurus.org/uat/1507> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "Solar motion"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1478> , <http://astrothesaurus.org/uat/46> , <http://astrothesaurus.org/uat/54> ;
	skos:related <http://astrothesaurus.org/uat/1615> ;
	skos:scopeNote "With respect to nearby stars"@en .

<http://astrothesaurus.org/uat/1521> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T15:57:43.274Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "Solar radiation"@en ;
	skos:definition "All the constituents making up the Sun's emission: photons, electrons, protons, neutrinos, and atomic nuclei."@en .

<http://astrothesaurus.org/uat/1524> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T15:59:02.762Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "Solar rotation"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1996> ;
	skos:related <http://astrothesaurus.org/uat/1629> ;
	skos:definition "The motion of the Sun around an axis which is roughly perpendicular to the plane of the ecliptic; the Sun's rotational axis is tilted by 7.25° from perpendicular to the ecliptic. It rotates in the counterclockwise direction (when viewed from the north), the same direction that the planets rotate (and orbit around the Sun). The Sun's rotation is differential, i.e. the period varies with latitude on the Sun (differential rotation). Equatorial regions rotate in about 25.6 days. The regions at 60 degrees latitude rotate more slowly, in about 30.9 days."@en .

<http://astrothesaurus.org/uat/1534> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2025-12-16T19:53:20.251Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ardc.edu.au/user/829848bd-c5e5-4a4f-8dab-a4a93998df19> ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "Solar wind"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1872> , <http://astrothesaurus.org/uat/1873> , <http://astrothesaurus.org/uat/707> ;
	skos:related <http://astrothesaurus.org/uat/827> , <http://astrothesaurus.org/uat/1636> ;
	skos:definition "A mass outflow, consisting of protons, electrons, and other subatomic particles, expelled constantly from the solar corona at about 500 km per second. The solar mass-loss rate in this phenomenon amounts to about 2 x 10^-14 solar masses per year, or about 106 tons per second."@en .

<http://astrothesaurus.org/uat/261> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "CNO anomaly"@en .

<http://astrothesaurus.org/uat/709> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T16:13:23.555Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "Helioseismology"@en ;
	skos:narrower <http://astrothesaurus.org/uat/708> , <http://astrothesaurus.org/uat/1487> , <http://astrothesaurus.org/uat/1503> ;
	skos:related <http://astrothesaurus.org/uat/1500> , <http://astrothesaurus.org/uat/73> ;
	skos:definition "The branch of astrophysics that investigates the interior structure of the Sun by studying its surface wave oscillations.  The surface of the Sun vibrates much like a bell. A piano has 88 keys or musical tones, whereas the Sun has millions of notes. These vibrations are the result of internal pressure waves that reflect off the photosphere and repeatedly cross the solar interior. They are detected through the Doppler shift of absorption lines formed in the photosphere. Because these vibrations make the solar surface move up and down, analysis of the surface patterns is used to study conditions far below the Sun's surface. The mean period of the vibrations is about five minutes, which corresponds to a frequency of about 3 mHz."@en .

<http://astrothesaurus.org/uat/1693> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:35:54.502Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1528> ;
	skos:prefLabel "The Sun"@en ;
	skos:related <http://astrothesaurus.org/uat/1941> , <http://astrothesaurus.org/uat/1476> ;
	skos:definition "The star that governs the solar system. It is a yellow main-sequence star of spectral type G2, shines with apparent magnitude -26.74, and has an absolute magnitude of +4.83. The Sun is 4.6 billion years old and lies 27,000 light-years from the Galactic center."@en .

<http://astrothesaurus.org/uat/1483> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2025-12-16T20:18:01.909Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ardc.edu.au/user/829848bd-c5e5-4a4f-8dab-a4a93998df19> ;
	skos:broader <http://astrothesaurus.org/uat/1477> ;
	skos:prefLabel "Solar corona"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1988> , <http://astrothesaurus.org/uat/1989> , <http://astrothesaurus.org/uat/1990> , <http://astrothesaurus.org/uat/1991> , <http://astrothesaurus.org/uat/1992> , <http://astrothesaurus.org/uat/1993> , <http://astrothesaurus.org/uat/1994> , <http://astrothesaurus.org/uat/1995> , <http://astrothesaurus.org/uat/2038> , <http://astrothesaurus.org/uat/2039> , <http://astrothesaurus.org/uat/2042> , <http://astrothesaurus.org/uat/1532> , <http://astrothesaurus.org/uat/312> , <http://astrothesaurus.org/uat/1484> , <http://astrothesaurus.org/uat/1485> , <http://astrothesaurus.org/uat/1486> ;
	skos:related <http://astrothesaurus.org/uat/305> ;
	skos:definition "The outermost atmosphere of the Sun immediately above the chromosphere, which can be seen during a total solar eclipse. It consists of hot, extremely tenuous gas extending for millions of kilometers from the Sun's surface."@en .

<http://astrothesaurus.org/uat/1518> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T15:56:04.049Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1477> ;
	skos:prefLabel "Solar photosphere"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1875> ;
	skos:related <http://astrothesaurus.org/uat/1237> ;
	skos:definition "The visible surface of the Sun (temperature 5700 K), just below the chromosphere and just above the convective zone. The solar photosphere is a thin layer of roughly 300 km wide. Its temperature decreases uniformly with height, from about 6,600 K (pressure 0.868 millibars) at its bottom, to about 4,400 K (pressure 125 mb), where it merges with the chromosphere. The photosphere has a 'rice-grain' appearance, called granulation, caused by rising (hot) and falling (cool) material in the convective cells just below the photosphere. Other main features of the photosphere are sunspots, faculae, and supergranulation."@en .

<http://astrothesaurus.org/uat/1478> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1507> ;
	skos:prefLabel "Solar atmospheric motions"@en .

<http://astrothesaurus.org/uat/1481> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T17:18:01.914Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/80> ;
	skos:prefLabel "Solar constant"@en ;
	skos:definition "The amount of solar radiation in all wavelengths received per unit of time per unit of area on a theoretical surface perpendicular to the Sun's rays and at Earth's mean distance from the Sun. Its mean value is 1367.7 W m^-2 or 1.37 x 106 erg sec^-1 cm^-2. In other words, the solar constant is the mean solar irradiance on the outer atmosphere when the Sun and Earth are spaced at 1 astronomical unit."@en .

<http://astrothesaurus.org/uat/1484> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T20:44:53.719Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Solar M coronal region"@en , "M regions"@en , "M region"@en ;
	skos:broader <http://astrothesaurus.org/uat/1483> ;
	skos:prefLabel "Solar coronal holes"@en ;
	skos:related <http://astrothesaurus.org/uat/307> ;
	skos:definition "An area in the solar corona which appears dark in X-rays and ultraviolet light. The gas density in these areas are very low, about 100 times less than that of coronal active regions. The magnetic field lines in a coronal hole extend out into interplanetary space rather than returning to the Sun's surface, as they do in other parts of the Sun (open magnetic field line). Ionized hot gas can escape easily along such a path, and this brings about high speed solar wind streams."@en .

<http://astrothesaurus.org/uat/1485> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T15:07:19.723Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1483> ;
	skos:prefLabel "Solar coronal loops"@en ;
	skos:related <http://astrothesaurus.org/uat/309> ;
	skos:definition "An arc-like structure in the Sun's corona that is found around sunspots and in active regions. These structures are associated with the closed magnetic field lines that connect magnetic regions on the solar surface. The loops are sometimes as high as 10,000 km with their two ends situated in photosphere regions of opposite magnetic polarity. This implies that the coronal loops are tubes of magnetic flux filled with hot plasma. They last for days or weeks but most change quite rapidly."@en .

<http://astrothesaurus.org/uat/1486> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T15:09:04.255Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1483> ;
	skos:prefLabel "Solar coronal streamers"@en ;
	skos:definition "A bright, narrow stream of particles traveling through the Sun's corona, visible in images taken with a coronagraph or during a total solar eclipse. Coronal streamers represent the most outwardly extended structures in the solar corona and result from the interaction between the solar slow wind and the large-scale magnetic field."@en .

<http://astrothesaurus.org/uat/1650> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1487> ;
	skos:prefLabel "Sunspot cycle"@en ;
	skos:related <http://astrothesaurus.org/uat/1653> .

<http://astrothesaurus.org/uat/18> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-02T15:26:33.351Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1487> ;
	skos:prefLabel "Active sun"@en ;
	skos:related <http://astrothesaurus.org/uat/1322> ;
	skos:definition "The Sun during its 11-year cycle of activity when spots, flares, prominences, and variations in radiofrequency radiation are at a maximum."@en .

<http://astrothesaurus.org/uat/1488> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T17:16:11.600Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "Solar radius"@en ;
	skos:related <http://astrothesaurus.org/uat/1626> ;
	skos:definition "A unit of length, representing the radius of the Sun, used to express the size of stars in astrophysics. It is equivalent to: 695,700 km, 0.00465047 astronomical units, 7.35355 x 10^-8 light-years, and 2.32061 light-seconds."@en .

<http://astrothesaurus.org/uat/378> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:11:10.469Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1489> ;
	skos:prefLabel "Diamond ring effect"@en ;
	skos:definition "An intense flash of light that happens a few seconds before and after totality during a solar eclipse. The effect is caused by the last rays of sunlight before totality (or the first rays of sunlight after totality) shining through valleys on the edge of the Moon."@en .

<http://astrothesaurus.org/uat/541> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T17:25:19.555Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Flash spectrum"@en ;
	skos:broader <http://astrothesaurus.org/uat/1489> ;
	skos:prefLabel "Flash spectra"@en ;
	skos:definition "The spectrum of the solar chromosphere obtained during a solar eclipse in the instant before or after totality. In the flash spectrum the usual solar absorption lines are replaced with bright emission lines. This is because in that very short interval only the photosphere is eclipsed by the Moon, and not the chromosphere. The American astronomer Charles A. Young was the first to observe it during the solar eclipse of 1870 (December 22) in Spain."@en .

<http://astrothesaurus.org/uat/444> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-05T15:45:03.900Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Eclipsing binaries"@en , "Eclipsing stars"@en , "Eclipsing variable stars"@en , "Photometric binary stars"@en ;
	skos:broader <http://astrothesaurus.org/uat/154> , <http://astrothesaurus.org/uat/514> ;
	skos:prefLabel "Eclipsing binary stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/149> , <http://astrothesaurus.org/uat/24> , <http://astrothesaurus.org/uat/1783> , <http://astrothesaurus.org/uat/1749> ;
	skos:definition "A binary star in which one of the two stars passes in front of the other so that the system's total light periodically fades. The most famous eclipsing binary is Algol."@en .

<http://astrothesaurus.org/uat/1493> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Solar EUV emission"@en ;
	skos:broader <http://astrothesaurus.org/uat/1490> ;
	skos:prefLabel "Solar extreme ultraviolet emission"@en .

<http://astrothesaurus.org/uat/1522> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1490> ;
	skos:prefLabel "Solar radio emission"@en .

<http://astrothesaurus.org/uat/1533> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Solar UV emission"@en ;
	skos:broader <http://astrothesaurus.org/uat/1490> ;
	skos:prefLabel "Solar ultraviolet emission"@en .

<http://astrothesaurus.org/uat/1536> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2019-12-13T21:25:49.326Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1490> ;
	skos:prefLabel "Solar x-ray emission"@en .

<http://astrothesaurus.org/uat/1508> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T15:27:38.330Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Solar nebula"@en ;
	skos:broader <http://astrothesaurus.org/uat/1492> ;
	skos:prefLabel "Solar nebulae"@en ;
	skos:related <http://astrothesaurus.org/uat/1530> ;
	skos:definition "The cloud of interstellar gas and dust from which the Sun and the rest of the solar system initially formed."@en .

<http://astrothesaurus.org/uat/1662> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1498> ;
	skos:prefLabel "Supergranulation"@en .

<http://astrothesaurus.org/uat/1499> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T15:25:57.246Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Solar instrumentation"@en ;
	skos:broader <http://astrothesaurus.org/uat/799> ;
	skos:prefLabel "Solar instruments"@en ;
	skos:definition "An instrument especially designed for solar observations."@en .

<http://astrothesaurus.org/uat/150> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/343> ;
	skos:prefLabel "Bianchi cosmology"@en .

<http://astrothesaurus.org/uat/1502> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1525> ;
	skos:prefLabel "Solar macrospicules"@en .

<http://astrothesaurus.org/uat/1503> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T16:01:19.964Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1476> , <http://astrothesaurus.org/uat/709> ;
	skos:prefLabel "Solar magnetic fields"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1984> , <http://astrothesaurus.org/uat/2000> , <http://astrothesaurus.org/uat/2001> , <http://astrothesaurus.org/uat/1504> ;
	skos:related <http://astrothesaurus.org/uat/1610> ;
	skos:definition "The Sun's magnetic field which is probably created by the differential rotation of the Sun together with the movement of charged particles in the convective zone. Understanding how the solar magnetic field comes about is the fundamental problem of Solar Physics. The solar magnetic field is responsible for all solar magnetic phenomena, such as sunspots, solar flares, coronal mass ejections, and the solar wind. The solar magnetic fields are observed from the Zeeman broadening of spectral lines, polarization effects on radio emission, and from the channeling of charged particles into visible coronal streamers. The strength of Sun's average magnetic field is 1 gauss (twice the average field on the surface of Earth, around 0.5 gauss), and can be as strong as 4,000 Gauss in the neighborhood of a large sunspot."@en .

<http://astrothesaurus.org/uat/1504> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1503> ;
	skos:prefLabel "Solar magnetic reconnection"@en .

<http://astrothesaurus.org/uat/1506> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T15:52:29.364Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "Solar mass"@en ;
	skos:related <http://astrothesaurus.org/uat/1614> ;
	skos:definition "The amount of mass in our Sun, about 330,000 times the Earth's mass. The solar mass is also the unit in which the masses of other stars, galaxies, and other large celestial bodies are expressed."@en .

<http://astrothesaurus.org/uat/46> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T17:59:53.711Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Solar antapex"@en ;
	skos:broader <http://astrothesaurus.org/uat/1507> ;
	skos:prefLabel "Antapex"@en ;
	skos:definition "The direction in the sky (in the constellation Columba) away from which the Sun seems to be moving (at a speed of 19.4 km/s) relative to general field stars in the Galaxy."@en .

<http://astrothesaurus.org/uat/54> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T18:06:25.985Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Solar apex"@en ;
	skos:broader <http://astrothesaurus.org/uat/1507> ;
	skos:prefLabel "Apex"@en ;
	skos:definition "The point on the celestial sphere toward which the Sun is apparently moving relative to the local standard of rest. Its position, in the constellation Hercules, is approximately R.A. 18h, Dec. +30°, close to the star Vega. The velocity of this motion is estimated to be about 19.4 km/sec (about 4 AU/year). As a result of this motion, stars seem to be converging toward a point in the opposite direction, the solar antapex."@en .

<http://astrothesaurus.org/uat/1512> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1517> ;
	skos:prefLabel "Solar neutrons"@en .

<http://astrothesaurus.org/uat/1516> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T15:55:05.145Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1618> ;
	skos:prefLabel "Solar parallax"@en ;
	skos:definition "The angle subtended (8''.79) by the equatorial radius of the Earth at a distance of 1 astronomical unit."@en .

<http://astrothesaurus.org/uat/697> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Hadron epoch"@en ;
	skos:broader <http://astrothesaurus.org/uat/152> ;
	skos:prefLabel "Hadron barrier"@en .

<http://astrothesaurus.org/uat/532> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T15:19:48.006Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Fibrills"@en ;
	skos:broader <http://astrothesaurus.org/uat/1525> ;
	skos:prefLabel "Solar fibrils"@en ;
	skos:definition "A linear pattern in the chromosphere of the Sun, as seen through an H-alpha filter, occurring near strong sunspots and plages or in filament channels. They are magnetically confined tubes of hot plasma. Individually, they are about 10,000 km long and last for 10 to 20 minutes."@en .

<http://astrothesaurus.org/uat/70> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-02T21:49:42.735Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1528> ;
	skos:prefLabel "Asteroid belt"@en ;
	skos:related <http://astrothesaurus.org/uat/2036> , <http://astrothesaurus.org/uat/72> ;
	skos:definition "The region of the solar system located between Mars and Jupiter where over a million objects bigger than 1 km across orbit the Sun."@en .

<http://astrothesaurus.org/uat/893> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T18:10:57.459Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Edgeworth-Kuiper belt"@en , "Edgeworth–Kuiper belt"@en ;
	skos:broader <http://astrothesaurus.org/uat/1528> ;
	skos:prefLabel "Kuiper belt"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1705> ;
	skos:definition "A region of the Solar System extending roughly from the orbit of Neptune, or 30 astronomical units (AU), to 50 AU from the Sun that contains many small icy bodies. The Kuiper belt is now considered to be the source of the short-period comets."@en .

<http://astrothesaurus.org/uat/333> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T19:47:31.736Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Cosmogeny"@en ;
	skos:broader <http://astrothesaurus.org/uat/343> ;
	skos:prefLabel "Cosmogony"@en ;
	skos:related <http://astrothesaurus.org/uat/1528> ;
	skos:definition "A philosophical, religious, or mythical story of the creation or origin of the Universe, usually referring to the solar system."@en .

<http://astrothesaurus.org/uat/436> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:34:33.704Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Earth moon system"@en ;
	skos:broader <http://astrothesaurus.org/uat/1529> ;
	skos:prefLabel "Earth-moon system"@en ;
	skos:definition "A physical system composed on the Earth and the Moon in which both objects directly influence each other. The total energy in the Earth-Moon system is conserved. The most notable influence that the two objects have on each other is tides."@en .

<http://astrothesaurus.org/uat/283> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T18:55:27.225Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Compact object binaries"@en ;
	skos:broader <http://astrothesaurus.org/uat/801> , <http://astrothesaurus.org/uat/254> ;
	skos:prefLabel "Compact binary stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/153> , <http://astrothesaurus.org/uat/1811> ;
	skos:definition "A binary star system which is composed of a collapsed object (degenerate dwarf, neutron star, or black hole) in orbit with a low-mass (≤ 0.5 M_sol) secondary star, wherein the collapsed star accretes matter from its companion. These two objects form a binary system of overall dimensions 10^6 km with an orbital period of only hours or less."@en .

<http://astrothesaurus.org/uat/707> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T16:12:22.822Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/711> , <http://astrothesaurus.org/uat/1534> ;
	skos:prefLabel "Heliopause"@en ;
	skos:definition "The edge of the solar system where the pressure of the solar wind balances that of the interstellar medium plasma. In other words, the surface boundary that separates the heliosphere from interstellar space. It is estimated to be situated 100 astronomical units or more from the Sun. A bow shock likely forms as the interstellar medium wind approaches the heliosphere and is deflected around the heliosphere, forcing it into a teardrop-shaped structure with a long, comet-like tail."@en .

<http://astrothesaurus.org/uat/1636> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Stellar outflows"@en ;
	skos:broader <http://astrothesaurus.org/uat/1576> , <http://astrothesaurus.org/uat/1621> ;
	skos:prefLabel "Stellar winds"@en ;
	skos:related <http://astrothesaurus.org/uat/1534> .

<http://astrothesaurus.org/uat/1535> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/827> ;
	skos:prefLabel "Solar wind termination"@en .

<http://astrothesaurus.org/uat/1537> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:01:46.581Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/467> ;
	skos:prefLabel "Solstice"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1649> , <http://astrothesaurus.org/uat/1804> ;
	skos:definition "Either of the two points on the ecliptic at which the apparent longitude of the Sun is 90° or 270°. Also the time at which the Sun is at either point. Solstices occur when the Earth's axis is oriented directly toward or away from the Sun, causing the Sun to reach its northernmost and southernmost extremes."@en .

<http://astrothesaurus.org/uat/1649> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:24:59.019Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1537> ;
	skos:prefLabel "Summer solstice"@en ;
	skos:definition "The moment in the northern hemisphere when the Sun attains its highest declination of 23°26' (or 23°.44) with respect the equator plane. It happens when the Earth's axis is orientated directly toward the Sun, on 21 or 22 June. During the northern solstice the Sun appears to be directly overhead at noon for places situated at latitude 23.44 degrees north, known as the tropic of Cancer. The summer solstice can occur at any moment during the day. Two successive summer solstices are shifted in time by about 6 h. The summer solstice in the northern hemisphere is the winter solstice in the southern hemisphere."@en .

<http://astrothesaurus.org/uat/1804> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T17:06:06.191Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1537> ;
	skos:prefLabel "Winter solstice"@en ;
	skos:definition "The moment in the northern hemisphere when the Sun attains its lowest declination of -23°26' (or -23°.44) with respect the equator plane. It happens when the Earth's axis is orientated directly away from the Sun, on 21 or 22 December. During the northern winter solstice the Sun appears to be directly overhead at noon for places situated at latitude 23.44 degrees south, known as the tropic of Capricorn. The winter solstice can occur at any moment during the day. Two successive winter solstices are shifted in time by about 6 h. The winter solstice in the northern hemisphere is the summer solstice in the southern hemisphere."@en .

<http://astrothesaurus.org/uat/1538> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:02:33.861Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "S c p"@en , "S. c. p."@en ;
	skos:broader <http://astrothesaurus.org/uat/213> ;
	skos:prefLabel "South celestial pole"@en ;
	skos:definition "The point in the southern hemisphere where the rotation axis of the Earth touches the celestial sphere. In contrast to the north celestial pole, no bright star is visible in that direction."@en .

<http://astrothesaurus.org/uat/1539> a rdfs:Resource , skos:Concept ;
	skos:altLabel "S e p"@en , "S. e. p."@en ;
	skos:broader <http://astrothesaurus.org/uat/448> ;
	skos:prefLabel "South ecliptic pole"@en .

<http://astrothesaurus.org/uat/1557> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T16:53:25.245Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Spectroscopic binaries"@en , "Spectrum binary stars"@en ;
	skos:broader <http://astrothesaurus.org/uat/154> ;
	skos:prefLabel "Spectroscopic binary stars"@en .

<http://astrothesaurus.org/uat/1777> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Visual binaries"@en ;
	skos:broader <http://astrothesaurus.org/uat/154> ;
	skos:prefLabel "Visual binary stars"@en .

<http://astrothesaurus.org/uat/1801> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T21:09:47.096Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/154> ;
	skos:prefLabel "Wide binary stars"@en ;
	skos:definition "A binary system with semi-major axis as large as 10,000 astronomical units."@en .

<http://astrothesaurus.org/uat/254> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T19:00:01.649Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Close binaries"@en ;
	skos:broader <http://astrothesaurus.org/uat/154> ;
	skos:prefLabel "Close binary stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/801> , <http://astrothesaurus.org/uat/455> , <http://astrothesaurus.org/uat/283> , <http://astrothesaurus.org/uat/1835> ;
	skos:definition "A binary system in which the separation of the component stars is comparable to their diameters, so that they influence each other's evolution most commonly by the tidal forces."@en .

<http://astrothesaurus.org/uat/291> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-26T20:23:37.333Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Secondary stars"@en ;
	skos:broader <http://astrothesaurus.org/uat/154> ;
	skos:prefLabel "Companion stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1648> , <http://astrothesaurus.org/uat/1691> ;
	skos:definition "The fainter of the two stars in a binary star system."@en .

<http://astrothesaurus.org/uat/375> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-27T13:37:04.501Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/154> ;
	skos:prefLabel "Detached binary stars"@en ;
	skos:definition "A binary star system whose components are not in contact and in which no significant mass exchange is occurring."@en .

<http://astrothesaurus.org/uat/79> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-26T18:48:10.743Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Astrometric binaries"@en ;
	skos:broader <http://astrothesaurus.org/uat/154> ;
	skos:prefLabel "Astrometric binary stars"@en ;
	skos:definition "A binary star in which the presence of an unresolved companion is revealed by small oscillations in the movement of the visible component caused by the gravitational influence of the unseen component."@en .

<http://astrothesaurus.org/uat/806> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Interferometric binaries"@en ;
	skos:broader <http://astrothesaurus.org/uat/154> ;
	skos:prefLabel "Interferometric binary stars"@en .

<http://astrothesaurus.org/uat/1540> a rdfs:Resource , skos:Concept ;
	skos:altLabel "S g p"@en , "S. g. p."@en ;
	skos:broader <http://astrothesaurus.org/uat/570> ;
	skos:prefLabel "South galactic pole"@en .

<http://astrothesaurus.org/uat/1541> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/80> ;
	skos:prefLabel "Space astrometry"@en .

<http://astrothesaurus.org/uat/1542> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:03:14.375Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Debris"@en ;
	skos:broader <http://astrothesaurus.org/uat/1549> ;
	skos:prefLabel "Space debris"@en ;
	skos:definition "Man-made objects in orbit around the Earth that no longer serve any useful purpose. The estimated number of debris include about 22,000 tractable objects larger than 10 cm in all orbits, of which 2,200 are dead satellites and last stages of the rocket that put them in orbit. There are also left-overs from spacecraft and mission operations, such as bolts, lens caps, clamp bands, auxiliary motors, etc. The debris presents a threat because of their high speeds, which ranges between 15 and 20 km/sec. Also called space junk, space waste, orbital debris."@en .

<http://astrothesaurus.org/uat/1549> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/799> ;
	skos:prefLabel "Space vehicles"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1545> , <http://astrothesaurus.org/uat/1542> , <http://astrothesaurus.org/uat/1548> , <http://astrothesaurus.org/uat/68> , <http://astrothesaurus.org/uat/698> , <http://astrothesaurus.org/uat/2348> , <http://astrothesaurus.org/uat/2355> .

<http://astrothesaurus.org/uat/785> a rdfs:Resource , skos:Concept ;
	skos:altLabel "IRAS"@en ;
	skos:broader <http://astrothesaurus.org/uat/1543> , <http://astrothesaurus.org/uat/791> ;
	skos:prefLabel "Infrared Astronomical Satellite"@en .

<http://astrothesaurus.org/uat/23> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T17:53:03.726Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Alfven surface waves"@en , "Alfvén surface waves"@en , "Alfvén waves"@en ;
	skos:broader <http://astrothesaurus.org/uat/1479> , <http://astrothesaurus.org/uat/1544> ;
	skos:prefLabel "Alfven waves"@en ;
	skos:related <http://astrothesaurus.org/uat/1964> ;
	skos:definition "A magnetohydrodynamic wave in a magnetized plasma, arising as a result of restoring forces associated with the magnetic field. It is a transverse wave which propagates in the direction of the magnetic field. Also called magnetohydrodynamic wave."@en .

<http://astrothesaurus.org/uat/366> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Deep-space probes"@en ;
	skos:broader <http://astrothesaurus.org/uat/1545> ;
	skos:prefLabel "Deep space probes"@en .

<http://astrothesaurus.org/uat/545> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-30T19:50:38.255Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1545> ;
	skos:prefLabel "Flyby missions"@en ;
	skos:definition "A mission in which a trajectory takes a space probe close to a Solar System body (planet, satellite, asteroid, comet) but does not permit it to enter an orbit about the body."@en .

<http://astrothesaurus.org/uat/901> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T16:33:00.831Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1545> ;
	skos:prefLabel "Landers"@en ;
	skos:definition "A space probe designed to land on a planet or other solid celestial body."@en .

<http://astrothesaurus.org/uat/969> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T16:54:16.301Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1545> ;
	skos:prefLabel "Lunar probes"@en ;
