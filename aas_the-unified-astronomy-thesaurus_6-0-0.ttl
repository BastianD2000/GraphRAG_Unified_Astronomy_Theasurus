	skos:broader <http://astrothesaurus.org/uat/1800> ;
	skos:prefLabel "All-sky cameras"@en ;
	skos:narrower <http://astrothesaurus.org/uat/257> .

<http://astrothesaurus.org/uat/1805> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T21:07:55.107Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "WN-type stars"@en ;
	skos:broader <http://astrothesaurus.org/uat/1806> ;
	skos:prefLabel "WN stars"@en ;
	skos:definition "A Wolf-Rayet star whose spectrum is dominated by emission lines of ionized nitrogen: N II 3995 Å, N III 4634-4661 Å, N III 5314 Å, N IV 3479-3484 Å, N IV 4058 Å, N V 4603 Å, N V 4619 Å, and N V 4933-4944 Å. This type is divided in sub-types WN2 to WN11."@en .

<http://astrothesaurus.org/uat/1807> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/80> ;
	skos:prefLabel "Wolf diagram"@en .

<http://astrothesaurus.org/uat/1808> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T21:06:10.120Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Einstein-Rosen Bridge"@en ;
	skos:broader <http://astrothesaurus.org/uat/674> ;
	skos:prefLabel "Wormholes"@en ;
	skos:related <http://astrothesaurus.org/uat/886> ;
	skos:definition "A hypothetical topological feature, based on general relativity, that connects two different points like a 'tunnel' in space-time. The most common concept of a wormhole is an Einstein-Rosen bridge. A trip through the wormhole could take much less time than a journey between the same starting and ending points in normal space. Wormholes have various types, intra-universe wormholes (connecting two distant regions of our Universe with each other) and inter-universe wormholes (that connect our Universe with another universe)."@en .

<http://astrothesaurus.org/uat/1809> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T21:05:08.766Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "WZ Sge stars"@en ;
	skos:broader <http://astrothesaurus.org/uat/203> , <http://astrothesaurus.org/uat/418> ;
	skos:prefLabel "WZ Sagittae stars"@en ;
	skos:definition "A subclass of dwarf novae with an extremely long outburst period, comparable with that of a recurrent nova."@en .

<http://astrothesaurus.org/uat/181> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/652> ;
	skos:prefLabel "Brightest cluster galaxies"@en .

