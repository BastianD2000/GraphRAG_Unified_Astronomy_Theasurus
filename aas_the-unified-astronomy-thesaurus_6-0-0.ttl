	skos:broader <http://astrothesaurus.org/uat/1213> ;
	skos:prefLabel "Short period variable stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/148> , <http://astrothesaurus.org/uat/370> ;
	skos:definition "A variable star that has a relatively short period with respect to stars of similar types."@en .

<http://astrothesaurus.org/uat/1214> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:25:30.789Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/584> ;
	skos:prefLabel "Perseus Cluster"@en ;
	skos:definition "A galaxy cluster of about 12,000 members about 250 million light-years (redshift z = 0.0176) away, covering 4° of sky in the constellation Perseus. It is dominated by elliptical galaxies. At its center lies the radio source Perseus A. Also known as Abell 426 (Abell catalog)."@en .

<http://astrothesaurus.org/uat/584> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-02T16:18:47.571Z"^^xsd:dateTime ;
