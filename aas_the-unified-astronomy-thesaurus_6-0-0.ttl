<http://astrothesaurus.org/uat/762> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T16:49:42.708Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Expansion timescale"@en ;
	skos:broader <http://astrothesaurus.org/uat/339> ;
	skos:prefLabel "Hubble time"@en ;
	skos:definition "An estimate for the age of the Universe by presuming that the Universe has always expanded at the same rate as it is expanding today. It is the inverse of the Hubble-Lemaitre constant."@en .

<http://astrothesaurus.org/uat/34> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-26T18:38:05.301Z"^^xsd:dateTime ;
