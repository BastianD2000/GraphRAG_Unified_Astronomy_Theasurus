	skos:narrower <http://astrothesaurus.org/uat/1291> , <http://astrothesaurus.org/uat/1301> , <http://astrothesaurus.org/uat/1381> , <http://astrothesaurus.org/uat/1401> , <http://astrothesaurus.org/uat/155> , <http://astrothesaurus.org/uat/1667> , <http://astrothesaurus.org/uat/180> , <http://astrothesaurus.org/uat/278> , <http://astrothesaurus.org/uat/287> , <http://astrothesaurus.org/uat/352> , <http://astrothesaurus.org/uat/382> , <http://astrothesaurus.org/uat/413> , <http://astrothesaurus.org/uat/461> , <http://astrothesaurus.org/uat/535> , <http://astrothesaurus.org/uat/639> , <http://astrothesaurus.org/uat/693> , <http://astrothesaurus.org/uat/2215> ;
	skos:definition "A cloud of gas and dust in the interstellar space."@en .

<http://astrothesaurus.org/uat/1291> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Presolar nebula"@en ;
	skos:broader <http://astrothesaurus.org/uat/1095> ;
	skos:prefLabel "Pre-solar nebulae"@en .

<http://astrothesaurus.org/uat/1301> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:40:11.636Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Preplanetary nebulae"@en , "Protoplanetary nebula"@en , "PPN"@en ;
	skos:broader <http://astrothesaurus.org/uat/1095> ;
	skos:prefLabel "Protoplanetary nebulae"@en ;
	skos:definition "A short-lived transition object between the asymptotic giant branch (AGB) and planetary nebula phases."@en .

<http://astrothesaurus.org/uat/1381> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T21:27:27.153Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Reflection nebula"@en ;
	skos:broader <http://astrothesaurus.org/uat/1095> ;
	skos:prefLabel "Reflection nebulae"@en ;
	skos:related <http://astrothesaurus.org/uat/1325> ;
	skos:definition "A type of nebula that is visible from its reflection of starlight. Bright stars near reflection nebulae emit light into the region that is reflected by the large amount of dust there. The size of the dust grains causes blue light to be reflected more efficiently than red light, so these reflection nebulae frequently appear blue in color."@en .

<http://astrothesaurus.org/uat/1401> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Ring nebula"@en ;
	skos:broader <http://astrothesaurus.org/uat/1095> ;
	skos:prefLabel "Ring nebulae"@en .

<http://astrothesaurus.org/uat/155> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-02T16:27:59.361Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Bipolar nebula"@en ;
	skos:broader <http://astrothesaurus.org/uat/1095> ;
	skos:prefLabel "Bipolar nebulae"@en ;
	skos:definition "An interstellar cloud of ionized gas with two main lobes which lie symmetrically on either side of a central star. The bipolar shape is generally due to the ejection of material by the central star in opposing directions."@en .

<http://astrothesaurus.org/uat/1667> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T19:00:25.918Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/847> , <http://astrothesaurus.org/uat/1095> ;
	skos:prefLabel "Supernova remnants"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2215> ;
	skos:definition "The body of expanding gas ejected at a speed of about 10,000 km s^-1 by a supernova explosion, observed as a diffuse gaseous nebula, often with a shell-like structure. Supernova remnants are generally powerful radio sources. The evolution of the SNR can be divided into different phases according to the dominant physical processes. Simplified models are made for the first stages, to get an idea of typical time scales, expansion velocities, and sizes. The three main phases are: 1) the free expansion phase, 2) the Sedov-Taylor phase, and 3) the snowplow phase."@en .

<http://astrothesaurus.org/uat/180> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-02T16:28:38.476Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
