	skos:related <http://astrothesaurus.org/uat/1310> , <http://astrothesaurus.org/uat/882> , <http://astrothesaurus.org/uat/2109> .

<http://astrothesaurus.org/uat/1453> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T14:53:27.897Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
