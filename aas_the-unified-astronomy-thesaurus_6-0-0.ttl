<http://astrothesaurus.org/uat/57> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T18:08:40.752Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
