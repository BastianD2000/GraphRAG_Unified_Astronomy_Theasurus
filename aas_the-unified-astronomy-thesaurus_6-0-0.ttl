<http://astrothesaurus.org/uat/985> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2025-12-16T20:14:48.873Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ardc.edu.au/user/829848bd-c5e5-4a4f-8dab-a4a93998df19> ;
	skos:altLabel "Class M stars"@en , "M-type stars"@en ;
	skos:broader <http://astrothesaurus.org/uat/2051> , <http://astrothesaurus.org/uat/909> ;
	skos:prefLabel "M stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/988> , <http://astrothesaurus.org/uat/983> , <http://astrothesaurus.org/uat/986> , <http://astrothesaurus.org/uat/987> , <http://astrothesaurus.org/uat/1017> , <http://astrothesaurus.org/uat/982> ;
	skos:related <http://astrothesaurus.org/uat/1589> ;
	skos:definition "A cool, red star of spectral type M with a surface temperature less than 3600 K. The spectra of M stars are dominated by molecular bands, especially those of TiO. Naked-eye examples are Betelgeuse and Antares."@en .

<http://astrothesaurus.org/uat/1019> a rdfs:Resource , skos:Concept ;
