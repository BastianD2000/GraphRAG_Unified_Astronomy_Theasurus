<http://astrothesaurus.org/uat/2001> a rdfs:Resource , skos:Concept ;
	dcterms:created "2018-08-27T21:34:33.000Z"^^xsd:dateTime ;
	dcterms:modified "2020-11-19T15:46:43.590Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
