<http://astrothesaurus.org/uat/225> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T17:26:16.093Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
