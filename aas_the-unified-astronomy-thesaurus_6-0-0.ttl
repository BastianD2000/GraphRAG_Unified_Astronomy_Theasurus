<http://astrothesaurus.org/uat/2184> a rdfs:Resource , skos:Concept ;
	dcterms:created "2020-12-02T21:52:04.891Z"^^xsd:dateTime ;
	dcterms:modified "2020-12-02T22:01:42.543Z"^^xsd:dateTime ;
