<http://astrothesaurus.org/uat/1240> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:24:03.807Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
