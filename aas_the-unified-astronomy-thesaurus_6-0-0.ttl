	skos:prefLabel "Pre-main sequence stars"@en ;
	skos:related <http://astrothesaurus.org/uat/1289> , <http://astrothesaurus.org/uat/1834> ;
	skos:definition "A star that evolves in the Hayashi phase and has not yet reached the zero-age main sequence."@en .

<http://astrothesaurus.org/uat/1292> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:34:12.758Z"^^xsd:dateTime ;
