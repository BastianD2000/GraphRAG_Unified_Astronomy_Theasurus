	skos:prefLabel "Burst astrophysics"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1164> , <http://astrothesaurus.org/uat/1339> , <http://astrothesaurus.org/uat/1362> , <http://astrothesaurus.org/uat/1814> , <http://astrothesaurus.org/uat/629> ;
