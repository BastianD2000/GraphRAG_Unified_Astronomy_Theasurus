<http://astrothesaurus.org/uat/1704> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T19:55:40.013Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
