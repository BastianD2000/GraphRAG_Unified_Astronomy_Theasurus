	skos:prefLabel "Planetary atmospheres"@en ;
	skos:narrower <http://astrothesaurus.org/uat/437> , <http://astrothesaurus.org/uat/118> , <http://astrothesaurus.org/uat/1245> , <http://astrothesaurus.org/uat/1429> , <http://astrothesaurus.org/uat/1748> , <http://astrothesaurus.org/uat/1791> , <http://astrothesaurus.org/uat/2119> , <http://astrothesaurus.org/uat/2120> , <http://astrothesaurus.org/uat/2180> , <http://astrothesaurus.org/uat/2193> , <http://astrothesaurus.org/uat/2300> , <http://astrothesaurus.org/uat/2301> , <http://astrothesaurus.org/uat/2309> ;
