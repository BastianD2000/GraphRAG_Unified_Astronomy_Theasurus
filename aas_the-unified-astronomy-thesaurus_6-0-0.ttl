<http://astrothesaurus.org/uat/1307> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T19:12:58.529Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
