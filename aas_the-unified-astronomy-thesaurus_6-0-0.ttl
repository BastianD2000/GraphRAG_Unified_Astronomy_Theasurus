	skos:narrower <http://astrothesaurus.org/uat/1318> , <http://astrothesaurus.org/uat/2136> , <http://astrothesaurus.org/uat/2137> , <http://astrothesaurus.org/uat/2138> , <http://astrothesaurus.org/uat/2140> , <http://astrothesaurus.org/uat/2141> , <http://astrothesaurus.org/uat/2142> , <http://astrothesaurus.org/uat/2143> , <http://astrothesaurus.org/uat/2144> , <http://astrothesaurus.org/uat/2145> , <http://astrothesaurus.org/uat/2146> , <http://astrothesaurus.org/uat/2147> ;
	skos:related <http://astrothesaurus.org/uat/549> .

<http://astrothesaurus.org/uat/16> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-06T01:47:26.534Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "AGN"@en , "AGNs"@en ;
	skos:broader <http://astrothesaurus.org/uat/609> , <http://astrothesaurus.org/uat/739> , <http://astrothesaurus.org/uat/17> ;
	skos:prefLabel "Active galactic nuclei"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2033> , <http://astrothesaurus.org/uat/2034> , <http://astrothesaurus.org/uat/2035> , <http://astrothesaurus.org/uat/1347> , <http://astrothesaurus.org/uat/1319> , <http://astrothesaurus.org/uat/1341> , <http://astrothesaurus.org/uat/1344> , <http://astrothesaurus.org/uat/1348> , <http://astrothesaurus.org/uat/1352> , <http://astrothesaurus.org/uat/1388> , <http://astrothesaurus.org/uat/164> , <http://astrothesaurus.org/uat/2134> ;
	skos:related <http://astrothesaurus.org/uat/2017> , <http://astrothesaurus.org/uat/1358> ;
	skos:definition "A central region of an active galaxy, which is a light-year or less in diameter and has an abnormally high luminosity. The nucleus emits high energy radiation (gamma rays, X-rays, ultraviolet) and shows variability over various time-scales, sometimes very short (hours to weeks). Emission line spectra reveal high velocity motions up to 10^4 km s^-1. AGNs are divided into two main types. Type I refers to an AGN whose nucleus is visible (the spectra has both narrow and broad emission lines), while in type II AGN, the broad line region (BLR) is obscured and the lines are very narrow. This may be due either to the viewing angle or some intrinsic difference in structure."@en .

<http://astrothesaurus.org/uat/1663> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T18:56:03.596Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/98> ;
	skos:prefLabel "Supermassive black holes"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1319> ;
	skos:definition "A black hole of tremendous mass, equivalent to those of millions or even billions of stars, which is believed to exist and occupy the centers of many galaxies. The supermassive black hole residing in the center of our Milky Way Galaxy is the object Sgr A* with a mass of 4 x 10^6 solar masses within a radius of 100 astronomical units."@en .

<http://astrothesaurus.org/uat/1349> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T21:03:14.190Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Radio-loud quasars"@en ;
	skos:broader <http://astrothesaurus.org/uat/1319> ;
	skos:prefLabel "Radio loud quasars"@en ;
	skos:definition "A quasar that has the same characteristics as a radio-quiet quasar with the addition of having strong radio emissions."@en .

<http://astrothesaurus.org/uat/1354> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T21:03:48.423Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Radio-quiet quasars"@en ;
	skos:broader <http://astrothesaurus.org/uat/1319> ;
	skos:prefLabel "Radio quiet quasars"@en ;
	skos:definition "A type of quasar with weak radio emission. These types of quasars have strong emissions in both the optical and X-ray spectra. Within the optical spectrum, both broad and narrow emission lines are present. Their host is usually an elliptical galaxy, but less commonly, it might be a spiral."@en .

<http://astrothesaurus.org/uat/1821> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1319> ;
	skos:prefLabel "X-ray quasars"@en .

<http://astrothesaurus.org/uat/183> a rdfs:Resource , skos:Concept ;
	skos:altLabel "BALQSO"@en ;
	skos:broader <http://astrothesaurus.org/uat/1319> ;
	skos:prefLabel "Broad-absorption line quasar"@en .

<http://astrothesaurus.org/uat/406> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1319> ;
	skos:prefLabel "Double quasars"@en .

<http://astrothesaurus.org/uat/1358> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T21:11:55.428Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Radio lines"@en ;
	skos:broader <http://astrothesaurus.org/uat/89> ;
	skos:prefLabel "Radio sources"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2008> , <http://astrothesaurus.org/uat/1339> , <http://astrothesaurus.org/uat/1340> , <http://astrothesaurus.org/uat/389> , <http://astrothesaurus.org/uat/508> , <http://astrothesaurus.org/uat/571> ;
	skos:related <http://astrothesaurus.org/uat/1338> , <http://astrothesaurus.org/uat/1353> , <http://astrothesaurus.org/uat/1319> , <http://astrothesaurus.org/uat/16> , <http://astrothesaurus.org/uat/1341> , <http://astrothesaurus.org/uat/1343> , <http://astrothesaurus.org/uat/1357> ;
	skos:definition "A point or small portion of the sky giving stronger radio emission than the sky in its vicinity."@en .

<http://astrothesaurus.org/uat/1320> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/159> ;
	skos:prefLabel "Quasinormal modes"@en .

<http://astrothesaurus.org/uat/1519> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Prominence"@en , "Solar eruptions"@en , "Solar prominence"@en , "Solar prominence eruptions"@en ;
	skos:broader <http://astrothesaurus.org/uat/1475> ;
	skos:prefLabel "Solar prominences"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1321> ;
	skos:related <http://astrothesaurus.org/uat/1495> ;
	skos:scopeNote "A solar filament, but seen above the limb."@en .

<http://astrothesaurus.org/uat/1322> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T20:00:10.084Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1487> ;
	skos:prefLabel "Quiet sun"@en ;
	skos:related <http://astrothesaurus.org/uat/1321> , <http://astrothesaurus.org/uat/18> ;
	skos:definition "The Sun when the 11-year cycle of solar activity is at a minimum."@en .

<http://astrothesaurus.org/uat/1487> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T15:46:01.601Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Solar activity cycles"@en , "Solar cycle variations"@en , "Solar magnetic activity cycle"@en , "Sun cycle"@en , "Sun cycles"@en ;
	skos:broader <http://astrothesaurus.org/uat/709> ;
	skos:prefLabel "Solar cycle"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2001> , <http://astrothesaurus.org/uat/1322> , <http://astrothesaurus.org/uat/1650> , <http://astrothesaurus.org/uat/18> ;
	skos:definition "The periodic variation in frequency or number of solar active events (sunspots, prominences, flares, and other solar activity) occurring with an interval of about 11 years. The solar cycle was discovered in 1843 by Samuel Heinrich Schwabe (1789-1875), a German apothecary and amateur astronomer, who after 17 years of observations noticed a periodic variation in the average number of sunspots seen from year to year on the solar disk. Solar cycle numbering goes back to the 18th century, when the Cycle 1 peak occurred in 1760. Cycle 23 peaked in 2000, and the following Cycle 24 will reach its maximum in 2013."@en .

<http://astrothesaurus.org/uat/1323> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-17T16:11:17.416Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/351> ;
	skos:prefLabel "Quintessence"@en ;
	skos:definition "In cosmology, a hypothetical new 'element,' distinct from any normal matter (either baryonic or not) or radiation, intended to explain the observed ever accelerating expansion of the Universe. Quintessence can have several types and differs from the cosmological constant in that it can vary in space and time. In modern physics, the four known \"elements\" are the baryons (proton, neutron, etc.), the leptons (neutrinos, electrons, etc.), the photon, and the hypothetical non-baryonic matter, which is thought to be 80% of the total matter in the Universe. The quintessence field is a possibility which can be confirmed or disproved by measurements of the dark energy value at different redshifts. In some models, the quintessence is fine-tuned to explain both the cosmological constant problem and the inflation in the very early Universe."@en .

<http://astrothesaurus.org/uat/351> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-06T02:02:15.493Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/339> ;
	skos:prefLabel "Dark energy"@en ;
	skos:narrower <http://astrothesaurus.org/uat/334> , <http://astrothesaurus.org/uat/1323> ;
	skos:definition "A hypothetical form of energy that fills all the space and tends to increase the rate of expansion of the Universe. Assuming the existence of dark energy is a way to explain recent observations that the Universe appears to be expanding at an increasing rate. Dark energy seems to be a kind of anti-gravity force and is supposed to be related to vacuum energy. Where gravity pulls things together at the more local level, dark energy tears them apart on the grander scale. The acceleration equation, one of Einstein's equations for the homogeneous Universe, indicates that if the Universe is accelerating, the pressure of the driving component should be strongly negative.  The first indication of dark energy was provided by the observation of Type Ia supernovae. Other probes of dark energy are: baryon acoustic oscillations, weak gravitational lensing, and clusters of galaxies. In the standard model of cosmology, dark energy currently accounts for almost 74% of the total mass-energy of the Universe. Two proposed forms for dark energy are the cosmological constant and exotic component such as quintessence."@en .

<http://astrothesaurus.org/uat/1325> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-05T20:27:39.924Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "R-association"@en ;
	skos:broader <http://astrothesaurus.org/uat/1582> ;
	skos:prefLabel "R associations"@en ;
	skos:related <http://astrothesaurus.org/uat/1381> ;
	skos:definition "A stellar association containing a number of reflection nebulae. The stars are of low or intermediate mass and young, less than a million years old. They are still surrounded by patches of dust that reflect and absorb light from the interstellar cloud in which they formed. This type of association was first suggested by Sidney van den Bergh."@en .

<http://astrothesaurus.org/uat/1327> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T15:47:45.708Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "R Coronae Borealis"@en , "R Coronae Borealis stars"@en , "R Coronae Borealis variables"@en , "R c b stars"@en , "R cor bor stars"@en , "R-Coronae Borealis variables"@en ;
	skos:broader <http://astrothesaurus.org/uat/865> , <http://astrothesaurus.org/uat/540> ;
	skos:prefLabel "R Coronae Borealis variable stars"@en .

<http://astrothesaurus.org/uat/540> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-03T20:40:14.356Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/476> ;
	skos:prefLabel "Flare stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1416> , <http://astrothesaurus.org/uat/1327> , <http://astrothesaurus.org/uat/1367> , <http://astrothesaurus.org/uat/553> , <http://astrothesaurus.org/uat/1755> ;
	skos:definition "A member of a class of dwarf stars that undergoes sudden, intense outbursts of light (mean amplitude about 0.5-0.6 mag)."@en .

<http://astrothesaurus.org/uat/133> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T18:40:41.782Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Bailys beads"@en ;
	skos:broader <http://astrothesaurus.org/uat/442> ;
	skos:prefLabel "Baily's beads"@en ;
	skos:definition "A phenomenon that occurs during a total eclipse of the Sun. Just prior to and after totality, sunlight shines through the lunar valleys on the Moon's limb, causing the dark face of the Moon to appear to be surrounded by a shining 'necklace of pearls'."@en .

<http://astrothesaurus.org/uat/1330> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1360> ;
	skos:prefLabel "Radar telescopes"@en .

<http://astrothesaurus.org/uat/1360> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T21:12:36.971Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1689> ;
	skos:prefLabel "Radio telescopes"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1330> , <http://astrothesaurus.org/uat/1345> , <http://astrothesaurus.org/uat/1361> , <http://astrothesaurus.org/uat/1460> , <http://astrothesaurus.org/uat/1523> , <http://astrothesaurus.org/uat/727> ;
	skos:definition "A telescope whose receiver is sensitive to radio waves."@en .

<http://astrothesaurus.org/uat/1331> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1625> ;
	skos:prefLabel "Radial pulsations"@en .

<http://astrothesaurus.org/uat/1332> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T19:17:57.273Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Astrometric radial velocity"@en , "Radial-velocity method"@en , "Spectroscopic radial velocity"@en , "Radial velocity methods"@en ;
	skos:broader <http://astrothesaurus.org/uat/80> , <http://astrothesaurus.org/uat/489> ;
	skos:prefLabel "Radial velocity"@en ;
	skos:definition "The component of a three-dimensional velocity vector of an object directed along the line of sight. It is measured by examining the Doppler shift of lines in the spectrum of astronomical objects."@en .

<http://astrothesaurus.org/uat/1334> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T20:03:56.971Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1629> ;
	skos:prefLabel "Radiative braking"@en ;
	skos:definition "The slowing down of a star's rotation due to radiative momentum transfer caused by emission of electromagnetic radiation."@en .

<http://astrothesaurus.org/uat/1629> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T17:24:35.632Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1624> ;
	skos:prefLabel "Stellar rotation"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1334> , <http://astrothesaurus.org/uat/680> ;
	skos:related <http://astrothesaurus.org/uat/1524> , <http://astrothesaurus.org/uat/1781> ;
	skos:definition "The spinning of a star about its axis, due to its angular momentum. Stars do not necessarily rotate as solid bodies, and their angular momentum may be distributed non-uniformly, depending on radius or latitude. Thus the equator of the star can rotate at a different angular velocity than the higher latitudes. These differences in the rate of rotation within a star may have a significant role in the generation of a stellar magnetic field."@en .

<http://astrothesaurus.org/uat/1335> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T20:05:16.250Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/343> ;
	skos:prefLabel "Radiative transfer"@en ;
	skos:related <http://astrothesaurus.org/uat/1336> ;
	skos:definition "The process by which the electromagnetic radiation passes through a medium that may contain any combination of scatterers, absorbers, and emitters."@en .

<http://astrothesaurus.org/uat/1336> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T16:41:07.724Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/38> ;
	skos:prefLabel "Radiative transfer equation"@en ;
	skos:related <http://astrothesaurus.org/uat/1335> ;
	skos:definition "The equation that describes the radiative transfer. It states that the specific intensity of radiation during its propagation in a medium is subject to losses due to extinction and to gains due to emission."@en .

<http://astrothesaurus.org/uat/1337> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1338> , <http://astrothesaurus.org/uat/80> ;
	skos:prefLabel "Radio astrometry"@en .

