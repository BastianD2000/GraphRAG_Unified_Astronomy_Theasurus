<http://astrothesaurus.org/uat/928> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T18:32:18.644Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1256> ;
	skos:prefLabel "Lithosphere"@en ;
	skos:definition "The solid portion of the Earth, as compared to the atmosphere and the hydrosphere. The lithosphere consists of semi-rigid plates that move relative to each other on the underlying asthenosphere. The process is known as plate tectonics and helps explain continental drift."@en .

