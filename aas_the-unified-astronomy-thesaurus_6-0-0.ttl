<http://astrothesaurus.org/uat/1722> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:45:13.874Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1462> ;
	skos:prefLabel "Twilight"@en ;
	skos:definition "The diffused light from the sky when the Sun is below the horizon, either from daybreak to sunrise or, more commonly, from sunset to nightfall. There are three types of twilight: astronomical twilight, civil twilight, and nautical twilight. They are divided on the basis of the solar depression angle."@en .

<http://astrothesaurus.org/uat/1463> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/80> ;
	skos:prefLabel "Sky noise"@en .

<http://astrothesaurus.org/uat/1464> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T14:55:30.148Z"^^xsd:dateTime ;
