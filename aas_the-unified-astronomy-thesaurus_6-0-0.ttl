<http://astrothesaurus.org/uat/1225> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:27:33.448Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
