	skos:altLabel "E galaxies"@en ;
	skos:broader <http://astrothesaurus.org/uat/573> ;
	skos:prefLabel "Elliptical galaxies"@en ;
	skos:narrower <http://astrothesaurus.org/uat/346> , <http://astrothesaurus.org/uat/651> ;
	skos:related <http://astrothesaurus.org/uat/362> , <http://astrothesaurus.org/uat/757> , <http://astrothesaurus.org/uat/582> ;
	skos:definition "A galaxy whose structure is smooth without spiral arms and ellipsoidal in shape. Ellipticals are redder than spirals of similar mass. Giant ellipticals contain over 1012 solar masses, whereas dwarf ellipticals have masses as low as 107 solar masses."@en .

