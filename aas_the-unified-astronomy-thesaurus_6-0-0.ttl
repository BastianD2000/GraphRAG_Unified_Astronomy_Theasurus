<http://astrothesaurus.org/uat/1528> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2022-06-15T19:32:22.690Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1529> ;
	skos:prefLabel "Solar system"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2037> , <http://astrothesaurus.org/uat/1089> , <http://astrothesaurus.org/uat/1040> , <http://astrothesaurus.org/uat/1509> , <http://astrothesaurus.org/uat/711> , <http://astrothesaurus.org/uat/1692> , <http://astrothesaurus.org/uat/1157> , <http://astrothesaurus.org/uat/1260> , <http://astrothesaurus.org/uat/1254> , <http://astrothesaurus.org/uat/419> , <http://astrothesaurus.org/uat/825> , <http://astrothesaurus.org/uat/1469> , <http://astrothesaurus.org/uat/1693> , <http://astrothesaurus.org/uat/70> , <http://astrothesaurus.org/uat/893> , <http://astrothesaurus.org/uat/2374> ;
	skos:related <http://astrothesaurus.org/uat/484> , <http://astrothesaurus.org/uat/1530> , <http://astrothesaurus.org/uat/333> , <http://astrothesaurus.org/uat/2293> ;
	skos:definition "The collective name for the Sun and all objects gravitationally bound to it. These objects are the eight planets, their 166 known moons, five dwarf planets, and billions of small bodies. The small bodies include asteroids, icy Kuiper belt objects, comets, meteoroids, and interplanetary dust. The solar system is roughly a sphere with a radius greater than 100,000 AU. Planets, satellites, and all interplanetary material together comprise only about 1/750 of the total mass. Geochemical dating methods show that the solar system chemically isolated itself from the rest of the Galaxy (4.7 ± 0.1) x 10^9 years ago."@en .

<http://astrothesaurus.org/uat/1048> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1040> ;
	skos:prefLabel "Micrometeoroids"@en .

<http://astrothesaurus.org/uat/538> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1041> ;
	skos:prefLabel "Fireballs"@en ;
	skos:narrower <http://astrothesaurus.org/uat/172> .

<http://astrothesaurus.org/uat/1042> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T17:36:48.209Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
