<http://astrothesaurus.org/uat/1476> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2025-12-16T18:03:09.441Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ardc.edu.au/user/829848bd-c5e5-4a4f-8dab-a4a93998df19> ;
	skos:altLabel "Astrophysics of the sun"@en , "Solar astronomy"@en , "Solar astrophysics"@en ;
	skos:broader <http://astrothesaurus.org/uat/2373> ;
	skos:prefLabel "Solar physics"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1501> , <http://astrothesaurus.org/uat/1515> , <http://astrothesaurus.org/uat/1517> , <http://astrothesaurus.org/uat/1527> , <http://astrothesaurus.org/uat/1490> , <http://astrothesaurus.org/uat/1500> , <http://astrothesaurus.org/uat/1653> , <http://astrothesaurus.org/uat/1498> , <http://astrothesaurus.org/uat/1496> , <http://astrothesaurus.org/uat/1474> , <http://astrothesaurus.org/uat/1475> , <http://astrothesaurus.org/uat/1477> , <http://astrothesaurus.org/uat/1492> , <http://astrothesaurus.org/uat/1494> , <http://astrothesaurus.org/uat/1507> , <http://astrothesaurus.org/uat/1521> , <http://astrothesaurus.org/uat/1524> , <http://astrothesaurus.org/uat/1534> , <http://astrothesaurus.org/uat/261> , <http://astrothesaurus.org/uat/709> , <http://astrothesaurus.org/uat/1488> , <http://astrothesaurus.org/uat/1503> , <http://astrothesaurus.org/uat/1506> ;
	skos:related <http://astrothesaurus.org/uat/1511> , <http://astrothesaurus.org/uat/1693> , <http://astrothesaurus.org/uat/1621> ;
	skos:scopeNote "Specifically the study of the Sun."@en , "The Sun is not primarily thought of as a subclass of star, because it is discussed with different words in a different literature by a different group of scientists. - jegpeek"@en ;
	skos:definition "The branch of astrophysics concerned with the study of the physical properties of the Sun based on the most detailed observations which can be obtained for a star."@en .

<http://astrothesaurus.org/uat/1577> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T16:30:26.798Z"^^xsd:dateTime ;
