	skos:prefLabel "Galactic poles"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1125> , <http://astrothesaurus.org/uat/1540> .

<http://astrothesaurus.org/uat/203> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T22:17:50.694Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Cataclysmic binaries"@en , "Cataclysmic binary stars"@en , "Cataclysmic variables"@en ;
	skos:broader <http://astrothesaurus.org/uat/859> , <http://astrothesaurus.org/uat/1443> ;
	skos:prefLabel "Cataclysmic variable stars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1672> , <http://astrothesaurus.org/uat/1126> , <http://astrothesaurus.org/uat/32> , <http://astrothesaurus.org/uat/1127> , <http://astrothesaurus.org/uat/1756> , <http://astrothesaurus.org/uat/1809> , <http://astrothesaurus.org/uat/31> ;
	skos:definition "A variable star that shows a sudden and dramatic change in brightness, including flare stars, novae, and some types of symbiotic stars. They are believed to be very close binary systems consisting of an accreting white dwarf primary and an evolved late-type secondary star that has filled its Roche lobe. For systems with an accretion disk, it is believed that a thermal instability is the cause of repetitive outbursts observed in cataclysmic variables called dwarf novae."@en .

<http://astrothesaurus.org/uat/1757> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1126> ;
	skos:prefLabel "UX Ursae Majoris stars"@en .

<http://astrothesaurus.org/uat/1782> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2024-06-20T12:31:47.203Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "VY Sculpturis stars"@en ;
	skos:broader <http://astrothesaurus.org/uat/1126> ;
	skos:prefLabel "VY Sculptoris stars"@en .

<http://astrothesaurus.org/uat/1127> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2025-12-16T20:14:08.896Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ardc.edu.au/user/829848bd-c5e5-4a4f-8dab-a4a93998df19> ;
	skos:broader <http://astrothesaurus.org/uat/1627> , <http://astrothesaurus.org/uat/1634> , <http://astrothesaurus.org/uat/203> ;
	skos:prefLabel "Novae"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1675> , <http://astrothesaurus.org/uat/407> , <http://astrothesaurus.org/uat/1366> , <http://astrothesaurus.org/uat/1467> , <http://astrothesaurus.org/uat/1818> , <http://astrothesaurus.org/uat/251> , <http://astrothesaurus.org/uat/418> , <http://astrothesaurus.org/uat/530> ;
	skos:related <http://astrothesaurus.org/uat/1164> ;
	skos:definition "A star that experiences a sudden increase in luminosity, by as much as 10^6. The outburst ejects a shell of matter but does not disrupt the star."@en .

<http://astrothesaurus.org/uat/1366> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T21:15:36.383Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1127> ;
	skos:prefLabel "Recurrent novae"@en ;
	skos:definition "A cataclysmic variable star that undergoes outbursts similar to those found in novae."@en .

<http://astrothesaurus.org/uat/1467> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T14:56:53.169Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Novoid"@en ;
	skos:broader <http://astrothesaurus.org/uat/1127> ;
	skos:prefLabel "Slow novae"@en ;
	skos:definition "A type of nova whose light curve exhibits a characteristically slow development, having a rise time of several days, maximum of several weeks, and slower decline."@en .

<http://astrothesaurus.org/uat/1818> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1127> ;
	skos:prefLabel "X-ray novae"@en .

<http://astrothesaurus.org/uat/251> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Classical nova"@en ;
	skos:broader <http://astrothesaurus.org/uat/1127> ;
	skos:prefLabel "Classical novae"@en .

<http://astrothesaurus.org/uat/418> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-05T15:43:28.710Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Dwarf nova"@en , "U Geminorum-type variable stars"@en ;
	skos:broader <http://astrothesaurus.org/uat/1127> ;
	skos:prefLabel "Dwarf novae"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1672> , <http://astrothesaurus.org/uat/1645> , <http://astrothesaurus.org/uat/1732> , <http://astrothesaurus.org/uat/1809> , <http://astrothesaurus.org/uat/1836> ;
	skos:definition "A class of novae and cataclysmic variables that have multiple observed eruptions. Their prototype is U Geminorum star. Optically, dwarf nova eruptions have amplitudes of 2-6 mag in V, a duration of a few to 20 days and a recurrence time-scale of weeks to years. Dwarf novae are thought to be semidetached binary stars consisting of a white dwarf primary accreting via Roche lobe overflow from a companion which is usually a late-type, generally main-sequence star. DN outbursts are usually attributed to the release of gravitational energy resulting from an instability in the accretion disk or by sudden mass transfers through the disk."@en .

<http://astrothesaurus.org/uat/530> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1127> ;
	skos:prefLabel "Fast novae"@en .

<http://astrothesaurus.org/uat/1164> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Optical outbursts"@en , "Outbursts"@en ;
	skos:broader <http://astrothesaurus.org/uat/187> ;
	skos:prefLabel "Optical bursts"@en ;
	skos:related <http://astrothesaurus.org/uat/154> , <http://astrothesaurus.org/uat/1127> .

<http://astrothesaurus.org/uat/1128> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/224> ;
	skos:prefLabel "Nuclear abundances"@en .

<http://astrothesaurus.org/uat/1131> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T19:44:58.436Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Element formation"@en , "Formation of elements"@en ;
	skos:broader <http://astrothesaurus.org/uat/1129> ;
	skos:prefLabel "Nucleosynthesis"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1193> , <http://astrothesaurus.org/uat/1195> , <http://astrothesaurus.org/uat/1324> , <http://astrothesaurus.org/uat/1419> , <http://astrothesaurus.org/uat/1457> , <http://astrothesaurus.org/uat/151> , <http://astrothesaurus.org/uat/1616> , <http://astrothesaurus.org/uat/195> , <http://astrothesaurus.org/uat/326> , <http://astrothesaurus.org/uat/503> , <http://astrothesaurus.org/uat/716> , <http://astrothesaurus.org/uat/768> ;
	skos:definition "The process by which nuclear reactions at very high temperatures and pressures produce the various chemical elements of the periodic table, either in the Big Bang or in stellar interiors."@en .

<http://astrothesaurus.org/uat/1511> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T15:30:10.327Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1129> , <http://astrothesaurus.org/uat/96> ;
	skos:prefLabel "Solar neutrinos"@en ;
	skos:related <http://astrothesaurus.org/uat/1517> , <http://astrothesaurus.org/uat/1476> ;
	skos:definition "A neutrino generated in the Sun. The main source of solar neutrinos is the proton-proton chain of reactions, in which an energy of +28 MeV is shared between the reaction products. These are called low-energy neutrinos. There are less important reactions in the Sun yielding a smaller flux of higher energy neutrinos. The solar neutrino flux can be estimated from the solar luminosity."@en .

