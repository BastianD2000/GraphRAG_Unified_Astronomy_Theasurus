<http://astrothesaurus.org/uat/169> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T20:46:37.113Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
