	skos:broader <http://astrothesaurus.org/uat/736> ;
	skos:prefLabel "Halo stars"@en .

<http://astrothesaurus.org/uat/710> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T16:14:14.801Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
