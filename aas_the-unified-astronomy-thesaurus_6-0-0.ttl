	skos:narrower <http://astrothesaurus.org/uat/1851> , <http://astrothesaurus.org/uat/1261> , <http://astrothesaurus.org/uat/1100> , <http://astrothesaurus.org/uat/353> , <http://astrothesaurus.org/uat/96> , <http://astrothesaurus.org/uat/187> , <http://astrothesaurus.org/uat/159> , <http://astrothesaurus.org/uat/870> , <http://astrothesaurus.org/uat/16> , <http://astrothesaurus.org/uat/1386> , <http://astrothesaurus.org/uat/1447> , <http://astrothesaurus.org/uat/162> , <http://astrothesaurus.org/uat/1786> , <http://astrothesaurus.org/uat/858> ;
	skos:topConceptOf <http://astrothesaurus.org/uat/1> ;
	skos:definition "A branch of astrophysics that deals with objects emitting highly energetic radiation, such as X-ray astronomy, gamma-ray astronomy, and extreme ultraviolet astronomy, as well as neutrinos and cosmic rays."@en .

