<http://astrothesaurus.org/uat/1833> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1160> ;
	skos:prefLabel "Young star clusters"@en .

<http://astrothesaurus.org/uat/1161> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:05:38.587Z"^^xsd:dateTime ;
