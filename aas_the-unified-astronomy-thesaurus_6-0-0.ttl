<http://astrothesaurus.org/uat/1694> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:36:35.857Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
