	skos:prefLabel "Optical position"@en .

<http://astrothesaurus.org/uat/1173> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T19:56:37.818Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1306> ;
	skos:prefLabel "Optical pulsars"@en ;
	skos:definition "A member of a rare class of pulsars, such as the Crab pulsar and Vela pulsar, which can be detected in the visible spectrum."@en .

<http://astrothesaurus.org/uat/1382> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T21:28:00.455Z"^^xsd:dateTime ;
