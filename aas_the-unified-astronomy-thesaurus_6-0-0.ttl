	skos:narrower <http://astrothesaurus.org/uat/119> , <http://astrothesaurus.org/uat/1106> , <http://astrothesaurus.org/uat/1120> , <http://astrothesaurus.org/uat/1168> , <http://astrothesaurus.org/uat/1221> , <http://astrothesaurus.org/uat/1346> , <http://astrothesaurus.org/uat/1552> , <http://astrothesaurus.org/uat/1775> , <http://astrothesaurus.org/uat/19> , <http://astrothesaurus.org/uat/386> , <http://astrothesaurus.org/uat/53> , <http://astrothesaurus.org/uat/726> , <http://astrothesaurus.org/uat/745> , <http://astrothesaurus.org/uat/807> , <http://astrothesaurus.org/uat/905> , <http://astrothesaurus.org/uat/932> ;
	skos:related <http://astrothesaurus.org/uat/805> ;
	skos:definition "An observational technique that uses the interference phenomenon to substantially increase the resolving power of telescopes."@en .

