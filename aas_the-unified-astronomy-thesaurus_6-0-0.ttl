<http://astrothesaurus.org/uat/268> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T19:28:29.531Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
