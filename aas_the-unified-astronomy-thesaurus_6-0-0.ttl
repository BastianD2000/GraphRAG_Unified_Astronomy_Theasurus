	skos:broader <http://astrothesaurus.org/uat/82> ;
	skos:prefLabel "Ecliptic coordinate system"@en ;
	skos:narrower <http://astrothesaurus.org/uat/448> , <http://astrothesaurus.org/uat/446> , <http://astrothesaurus.org/uat/447> , <http://astrothesaurus.org/uat/2336> , <http://astrothesaurus.org/uat/2337> ;
	skos:definition "Coordinate system with the ecliptic as the fundamental plane."@en .

<http://astrothesaurus.org/uat/446> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:38:29.461Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/445> ;
	skos:prefLabel "Ecliptic latitude"@en ;
	skos:definition "One of the two coordinates in the ecliptic system; the angle measured from the ecliptic, positive toward the north."@en .

<http://astrothesaurus.org/uat/447> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:42:04.985Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/445> ;
	skos:prefLabel "Ecliptic longitude"@en ;
	skos:definition "One of the two coordinates in the ecliptic system; the angle measured eastwards along the ecliptic from 0° to 360°, with the origin at the vernal equinox."@en .

<http://astrothesaurus.org/uat/449> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:43:09.848Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/80> ;
	skos:prefLabel "Effective temperature"@en ;
	skos:definition "A measure of the surface temperature of a star derived from the total emitted energy, assuming that the star is a blackbody emitter."@en .

<http://astrothesaurus.org/uat/450> a rdfs:Resource , skos:Concept ;
