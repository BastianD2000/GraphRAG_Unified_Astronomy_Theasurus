<http://astrothesaurus.org/uat/1475> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T15:29:53.786Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1476> ;
	skos:prefLabel "Solar activity"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1974> , <http://astrothesaurus.org/uat/1984> , <http://astrothesaurus.org/uat/1526> , <http://astrothesaurus.org/uat/1495> , <http://astrothesaurus.org/uat/1519> , <http://astrothesaurus.org/uat/1496> ;
	skos:related <http://astrothesaurus.org/uat/1580> ;
	skos:definition "The general term for all forms of short-lived phenomena on the Sun, including solar flares, sunspots, prominences, etc., indicating that the Sun is an active star."@en .

<http://astrothesaurus.org/uat/1477> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T22:11:43.264Z"^^xsd:dateTime ;
