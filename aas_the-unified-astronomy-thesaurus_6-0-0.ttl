	skos:broader <http://astrothesaurus.org/uat/850> ;
	skos:prefLabel "Hot ionized medium"@en , "Hot ionised medium"@en-gb .

<http://astrothesaurus.org/uat/759> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T16:47:51.519Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
