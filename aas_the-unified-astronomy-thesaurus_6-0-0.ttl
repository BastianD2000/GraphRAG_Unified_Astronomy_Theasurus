<http://astrothesaurus.org/uat/477> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2024-06-20T13:23:24.763Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
