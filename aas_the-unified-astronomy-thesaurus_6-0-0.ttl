	skos:broader <http://astrothesaurus.org/uat/1244> ;
	skos:prefLabel "Earth atmosphere"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1029> , <http://astrothesaurus.org/uat/1030> , <http://astrothesaurus.org/uat/112> , <http://astrothesaurus.org/uat/1150> , <http://astrothesaurus.org/uat/118> , <http://astrothesaurus.org/uat/1194> , <http://astrothesaurus.org/uat/1639> , <http://astrothesaurus.org/uat/1640> , <http://astrothesaurus.org/uat/1694> , <http://astrothesaurus.org/uat/1717> , <http://astrothesaurus.org/uat/1718> , <http://astrothesaurus.org/uat/258> , <http://astrothesaurus.org/uat/383> , <http://astrothesaurus.org/uat/499> , <http://astrothesaurus.org/uat/764> , <http://astrothesaurus.org/uat/900> , <http://astrothesaurus.org/uat/2311> , <http://astrothesaurus.org/uat/2314> ;
