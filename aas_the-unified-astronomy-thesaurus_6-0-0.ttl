<http://astrothesaurus.org/uat/1319> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2025-12-16T20:16:12.345Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ardc.edu.au/user/829848bd-c5e5-4a4f-8dab-a4a93998df19> ;
	skos:altLabel "QSO"@en , "Quasi-stellar galaxies"@en , "Quasi-stellar object"@en , "Quasi-stellar radio sources"@en ;
	skos:broader <http://astrothesaurus.org/uat/16> , <http://astrothesaurus.org/uat/1663> ;
	skos:prefLabel "Quasars"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1316> , <http://astrothesaurus.org/uat/1349> , <http://astrothesaurus.org/uat/1354> , <http://astrothesaurus.org/uat/1821> , <http://astrothesaurus.org/uat/183> , <http://astrothesaurus.org/uat/406> ;
	skos:related <http://astrothesaurus.org/uat/1358> ;
	skos:definition "A compact, extragalactic object which is highly luminous and looks like a star. Their redshifts can be large and their brightness varies. Quasars have an intrinsic luminosity which can reach some 100 times that of bright galaxies. They are thought to be active galactic nuclei with a size a little larger than the solar system. The first quasar to be identified as such, in 1963, was the radio source 3C 273 at a redshift of 0.158. With its 13th magnitude, it is the optically brightest quasar as observed from Earth. Some quasars are strong radio sources."@en .

<http://astrothesaurus.org/uat/1317> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/813> ;
	skos:prefLabel "Quasar absorption line spectroscopy"@en .

<http://astrothesaurus.org/uat/1318> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/672> ;
	skos:prefLabel "Quasar microlensing"@en .

<http://astrothesaurus.org/uat/672> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T19:15:33.423Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Microlensing"@en , "Planetary microlensing"@en , "Gravitational microlens"@en ;
