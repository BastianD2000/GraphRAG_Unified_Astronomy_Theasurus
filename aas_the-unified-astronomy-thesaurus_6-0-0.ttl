	skos:definition "A telescope in which an image is formed by the refraction of light through a lens or lens system."@en .

<http://astrothesaurus.org/uat/1514> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1174> , <http://astrothesaurus.org/uat/1531> ;
	skos:prefLabel "Solar optical telescopes"@en .

<http://astrothesaurus.org/uat/1175> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1184> ;
	skos:prefLabel "Orbit determination"@en .

<http://astrothesaurus.org/uat/1184> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:01:40.537Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Orbital dynamics"@en ;
	skos:broader <http://astrothesaurus.org/uat/211> ;
	skos:prefLabel "Orbits"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1175> , <http://astrothesaurus.org/uat/1177> , <http://astrothesaurus.org/uat/1179> , <http://astrothesaurus.org/uat/1180> , <http://astrothesaurus.org/uat/1181> , <http://astrothesaurus.org/uat/1182> , <http://astrothesaurus.org/uat/2296> ;
	skos:definition "The path followed by a body moving in a gravitational field. For bodies moving under the influence of a centrally directed force, without significant perturbation, the shape of the orbit must be one of the conic section family of curves (circle, ellipse, parabola, or hyperbola)."@en .

<http://astrothesaurus.org/uat/1177> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:09:09.607Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Keplerian elements"@en ;
	skos:broader <http://astrothesaurus.org/uat/1184> ;
	skos:prefLabel "Orbital elements"@en ;
	skos:narrower <http://astrothesaurus.org/uat/457> , <http://astrothesaurus.org/uat/1176> , <http://astrothesaurus.org/uat/1190> , <http://astrothesaurus.org/uat/1286> , <http://astrothesaurus.org/uat/1676> , <http://astrothesaurus.org/uat/216> , <http://astrothesaurus.org/uat/441> , <http://astrothesaurus.org/uat/63> , <http://astrothesaurus.org/uat/65> , <http://astrothesaurus.org/uat/66> , <http://astrothesaurus.org/uat/780> , <http://astrothesaurus.org/uat/936> , <http://astrothesaurus.org/uat/937> ;
	skos:definition "A fixed point in a body through which the resultant force of gravitational attraction acts."@en .

<http://astrothesaurus.org/uat/1719> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:43:29.981Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1176> ;
	skos:prefLabel "True anomaly"@en ;
	skos:definition "One of the standard orbital elements, which is the angle measured at the focus nearest the periapsis of an elliptical orbit, between the periapsis and the radius vector from the focus to the orbiting body."@en .

<http://astrothesaurus.org/uat/440> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:35:29.483Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1176> ;
	skos:prefLabel "Eccentric anomaly"@en ;
	skos:definition "Of a planetary orbit, the angle measured from the perihelion position, to the center of the circumscribing auxiliary circle, to the projected position of the planet on the circle."@en .

<http://astrothesaurus.org/uat/1190> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Osculatory elements"@en .

<http://astrothesaurus.org/uat/1286> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:49:45.408Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Position angle"@en ;
	skos:related <http://astrothesaurus.org/uat/1295> ;
	skos:definition "The convention for measuring angles on the sky in astronomy (abbreviated as PA). It is the direction of an imaginary arrow in the sky, measured from north through east: 0° = north, 90° = east, 180° = south, and so on to 359° and back to 0°. Applied to a binary system it is the direction of a secondary body or feature from a primary, measured in the system."@en .

<http://astrothesaurus.org/uat/1676> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:30:42.222Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Synodic period"@en ;
	skos:definition "For planets, the mean interval of time between successive conjunctions of two planets, as observed from the Earth. For satellites, the mean interval between successive conjunctions of a satellite with the Sun, as observed from the satellite's primary."@en .

<http://astrothesaurus.org/uat/216> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2021-08-24T15:25:06.254Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Centre of mass"@en , "Center of gravity"@en ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Center of mass"@en , "Centre of mass"@en-gb ;
	skos:definition "A fixed point in a body through which the resultant force of gravitational attraction acts."@en .

<http://astrothesaurus.org/uat/441> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:36:11.071Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Eccentricity"@en ;
	skos:definition "The amount by which the orbit deviates from circularity: e = c/a, where c is the distance from the center to a focus and a the semi-major axis. If e = 0, the orbit is a circle. If e < 1, the orbit is an ellipse, if e > 1 it is a hyperbola, and if e = 1 it is a parabola. The eccentricity is one of the six orbital elements that define a Keplerian orbit."@en .

<http://astrothesaurus.org/uat/63> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-26T18:44:18.583Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Apse"@en , "Apsis"@en ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Apsides"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1207> , <http://astrothesaurus.org/uat/1208> , <http://astrothesaurus.org/uat/1209> , <http://astrothesaurus.org/uat/1210> , <http://astrothesaurus.org/uat/51> , <http://astrothesaurus.org/uat/55> , <http://astrothesaurus.org/uat/56> , <http://astrothesaurus.org/uat/57> ;
	skos:definition "The point of greatest or least distance of the orbit of a celestial body from a center of attraction. The closest point is the periapsis, the further point the apoapsis."@en .

<http://astrothesaurus.org/uat/65> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T18:18:23.248Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Argument of perigee"@en ;
	skos:definition "The angular distance between the ascending node of an object orbiting the Earth and its perigee, measured from the Earth."@en .

<http://astrothesaurus.org/uat/66> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T18:19:14.364Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Argument of perihelion"@en ;
	skos:definition "The angular distance between the ascending node of an object orbiting the Sun and its perihelion. Argument of perihelion is measured in the orbital plane with respect to the Sun and in the direction of motion. It is one of the orbital elements and usually shown with the symbol ω."@en .

<http://astrothesaurus.org/uat/780> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T16:56:56.619Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Inclination"@en ;
	skos:definition "An orbital element that defines the angle between the orbital plane of a solar system body (planet, comet, asteroid) and the plane of the ecliptic."@en .

<http://astrothesaurus.org/uat/936> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T18:35:12.306Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Longitude of the ascending node"@en ;
	skos:definition "One of the orbital elements used to specify the orbit of an object in space. It is the angle from the reference direction, called the origin of longitude, to the direction of the ascending node, measured in the reference plane."@en .

<http://astrothesaurus.org/uat/937> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1177> ;
	skos:prefLabel "Longitude of the descending node"@en .

<http://astrothesaurus.org/uat/1178> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/336> ;
	skos:prefLabel "Orbital evolution"@en .

<http://astrothesaurus.org/uat/336> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Astronomical evolution"@en ;
	skos:broader <http://astrothesaurus.org/uat/343> ;
	skos:prefLabel "Cosmological evolution"@en ;
	skos:narrower <http://astrothesaurus.org/uat/594> , <http://astrothesaurus.org/uat/1178> , <http://astrothesaurus.org/uat/421> .

<http://astrothesaurus.org/uat/1179> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1184> ;
	skos:prefLabel "Orbital motion"@en ;
	skos:narrower <http://astrothesaurus.org/uat/457> , <http://astrothesaurus.org/uat/233> , <http://astrothesaurus.org/uat/1275> , <http://astrothesaurus.org/uat/1189> , <http://astrothesaurus.org/uat/1196> , <http://astrothesaurus.org/uat/1212> , <http://astrothesaurus.org/uat/465> , <http://astrothesaurus.org/uat/62> , <http://astrothesaurus.org/uat/643> , <http://astrothesaurus.org/uat/706> , <http://astrothesaurus.org/uat/773> , <http://astrothesaurus.org/uat/884> , <http://astrothesaurus.org/uat/917> , <http://astrothesaurus.org/uat/964> , <http://astrothesaurus.org/uat/2325> , <http://astrothesaurus.org/uat/2326> , <http://astrothesaurus.org/uat/2327> .

<http://astrothesaurus.org/uat/1189> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:14:13.783Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1179> ;
	skos:prefLabel "Osculating orbit"@en ;
	skos:definition "The Keplerian orbit that a satellite would follow after a specific time t if all forces other than central inverse-square forces ceased to act from time t on. An osculating orbit is tangent to the real, perturbed, orbit and has the same velocity at the point of tangency."@en .

<http://astrothesaurus.org/uat/1196> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-21T14:30:53.206Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1179> ;
	skos:prefLabel "Parabolic orbit"@en ;
	skos:definition "An orbit whose overall shape is like a parabola; it is the limiting case between an elliptical orbit (eccentricity less than 1) and a hyperbolic orbit (eccentricity larger than 1). The speed necessary to form a parabolic orbit is known as the escape velocity."@en .

<http://astrothesaurus.org/uat/1212> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1179> ;
	skos:prefLabel "Periodic orbit"@en .

<http://astrothesaurus.org/uat/465> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2021-08-24T15:25:45.815Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Equation of the centre"@en ;
	skos:broader <http://astrothesaurus.org/uat/1179> ;
	skos:prefLabel "Equation of the center"@en , "Equation of centre"@en-gb .

<http://astrothesaurus.org/uat/62> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T18:14:17.413Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1179> ;
	skos:prefLabel "Apsidal motion"@en ;
	skos:definition "Rotation of the line of apsides in the plane of the orbit in the same direction as the revolution of the secondary body. The major axis of the Earth's orbit rotates by 11.6 arcseconds per year."@en .

<http://astrothesaurus.org/uat/643> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1179> ;
	skos:prefLabel "Geocentric orbit"@en .

<http://astrothesaurus.org/uat/706> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1179> ;
	skos:prefLabel "Heliocentric orbit"@en .

<http://astrothesaurus.org/uat/773> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T16:54:02.370Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1179> ;
	skos:prefLabel "Hyperbolic orbit"@en ;
	skos:definition "An orbit that is an open curve whose ends get wider apart at any rate between that of an ellipse and a straight line. Some comets' orbits become hyperbolic through the gravitational influence of a planet the comet passes near."@en .

<http://astrothesaurus.org/uat/884> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T18:06:05.101Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1179> ;
	skos:prefLabel "Keplerian orbit"@en ;
	skos:definition "The orbit of a spherical object of a finite mass around another spherical object, also of finite mass, governed by their mutual gravitational forces only."@en .

<http://astrothesaurus.org/uat/917> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-10T18:16:12.227Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Physical libration"@en ;
	skos:broader <http://astrothesaurus.org/uat/1179> ;
	skos:prefLabel "Libration"@en ;
	skos:definition "Small oscillations of a celestial body about its mean position. The term is used mainly to mean the Moon's libration caused by the apparent wobble of the Moon as it orbits the Earth. The Moon always keeps the same side toward the Earth, but due to libration, 59% of the Moon's surface can be seen over a period of time. This results from three kinds of libration working in combination: libration in longitude, libration in latitude, and diurnal libration."@en .

<http://astrothesaurus.org/uat/964> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1179> , <http://astrothesaurus.org/uat/975> ;
	skos:prefLabel "Lunar node regression"@en .

<http://astrothesaurus.org/uat/118> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/437> , <http://astrothesaurus.org/uat/1244> , <http://astrothesaurus.org/uat/1702> ;
	skos:prefLabel "Atmospheric tides"@en .

<http://astrothesaurus.org/uat/1180> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:02:32.970Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Line of node"@en ;
	skos:broader <http://astrothesaurus.org/uat/1184> ;
	skos:prefLabel "Orbital nodes"@en ;
	skos:narrower <http://astrothesaurus.org/uat/374> , <http://astrothesaurus.org/uat/69> ;
	skos:definition "One of the two points of intersection of the orbit of a secondary body with the plane of reference through the primary."@en .

<http://astrothesaurus.org/uat/374> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:09:09.006Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "South node"@en ;
	skos:broader <http://astrothesaurus.org/uat/1180> ;
	skos:prefLabel "Descending node"@en ;
	skos:definition "The point in an orbit where the orbiting body crosses a reference plane, such as the ecliptic or the celestial equator, going from north to south."@en .

<http://astrothesaurus.org/uat/69> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T18:21:44.908Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "North node"@en ;
	skos:broader <http://astrothesaurus.org/uat/1180> ;
	skos:prefLabel "Ascending node"@en ;
	skos:definition "The point in an orbit where the orbiting body crosses a reference plane, such as the ecliptic or the celestial equator, going from south to north. The celestial longitude of the ascending node is one of the elements of the orbit."@en .

<http://astrothesaurus.org/uat/1181> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Orbital resonance gaps"@en ;
	skos:broader <http://astrothesaurus.org/uat/669> , <http://astrothesaurus.org/uat/1184> ;
	skos:prefLabel "Orbital resonances"@en ;
	skos:narrower <http://astrothesaurus.org/uat/889> .

<http://astrothesaurus.org/uat/889> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T16:27:55.240Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Kirkwood gap"@en ;
	skos:broader <http://astrothesaurus.org/uat/1181> ;
	skos:prefLabel "Kirkwood gaps"@en ;
	skos:definition "Regions in the asteroid belt within which few asteroids are found. The Kirkwood gaps are due to the perturbing effects of Jupiter through resonances with Jupiter's orbital period."@en .

<http://astrothesaurus.org/uat/1182> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1184> ;
	skos:prefLabel "Orbital theory"@en ;
	skos:narrower <http://astrothesaurus.org/uat/170> .

<http://astrothesaurus.org/uat/170> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T18:52:05.208Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Bodes law"@en , "Titius-Bode law"@en ;
	skos:broader <http://astrothesaurus.org/uat/1182> ;
	skos:prefLabel "Bode's law"@en ;
	skos:definition "The empirical rule relating the approximate distances of the solar system planets from the Sun. The original formulation was: a = (n + 4) / 10, where a is the mean distance of a planet from the Sun in astronomical units and n = 0, 3, 6, 12, 24, 48, 96, 192 (doubling for each successive planet). The planets were seen to fit this sequence quite well, provided the asteroids between Mars and Jupiter are counted as one planet, as did Uranus discovered in 1781. However, Neptune and the ex-planet Pluto do not conform to the rule. The question of whether there is any physical significance to the 'law,' i.e. some dynamical reason that will explain planetary orbit spacing has led to much discussion during the past two centuries. Today, many astronomers are very skeptical and consider this 'law' to be numerical coincidence."@en .

<http://astrothesaurus.org/uat/1183> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:03:39.342Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1545> ;
	skos:prefLabel "Orbiters"@en ;
	skos:definition "A spacecraft or satellite designed to orbit a planet or other solar system body."@en .

<http://astrothesaurus.org/uat/1545> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T16:17:05.398Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Probe"@en ;
	skos:broader <http://astrothesaurus.org/uat/1549> ;
	skos:prefLabel "Space probes"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1183> , <http://astrothesaurus.org/uat/1252> , <http://astrothesaurus.org/uat/1409> , <http://astrothesaurus.org/uat/366> , <http://astrothesaurus.org/uat/545> , <http://astrothesaurus.org/uat/901> , <http://astrothesaurus.org/uat/969> ;
	skos:definition "A spacecraft carrying instruments intended for use in exploration of the physical properties of outer space or celestial bodies other than Earth."@en .

<http://astrothesaurus.org/uat/1186> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Formation of the universe"@en ;
	skos:broader <http://astrothesaurus.org/uat/343> ;
	skos:prefLabel "Origin of the universe"@en ;
	skos:narrower <http://astrothesaurus.org/uat/435> , <http://astrothesaurus.org/uat/152> , <http://astrothesaurus.org/uat/1574> , <http://astrothesaurus.org/uat/763> .

<http://astrothesaurus.org/uat/152> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T18:47:46.044Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/343> , <http://astrothesaurus.org/uat/1186> ;
	skos:prefLabel "Big Bang theory"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1365> , <http://astrothesaurus.org/uat/151> , <http://astrothesaurus.org/uat/341> , <http://astrothesaurus.org/uat/1235> , <http://astrothesaurus.org/uat/1383> , <http://astrothesaurus.org/uat/697> ;
	skos:definition "A theory which states that the Universe came into existence in an 'instantaneous' event some 14 billion years ago. Matter was created in that initial event and as time has gone by the Universe has expanded and the contents evolved into the galaxies and stars and of today. The Big Bang is sometimes described as an 'explosion.' However, matter and energy did not erupt into a pre-existing space, since they came into being simultaneously with space and time."@en .

<http://astrothesaurus.org/uat/1574> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Steady state theory"@en ;
	skos:broader <http://astrothesaurus.org/uat/1186> ;
	skos:prefLabel "Steady-state theory"@en .

<http://astrothesaurus.org/uat/763> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-17T16:50:34.706Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Hubble law"@en , "Hubble's law"@en ;
	skos:broader <http://astrothesaurus.org/uat/1186> ;
	skos:prefLabel "Hubble-Lemaitre law"@en ;
	skos:narrower <http://astrothesaurus.org/uat/759> ;
	skos:definition "The speed with which a galaxy cluster recedes from us is directly proportional to its distance. It can be stated as v = H_{0}d, where v is the recessional velocity, H_0 the Hubble-Lemaitre constant, and d the distance."@en .

<http://astrothesaurus.org/uat/1187> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:17:37.408Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Orrery"@en ;
	skos:broader <http://astrothesaurus.org/uat/433> ;
	skos:prefLabel "Orreries"@en ;
	skos:definition "A mechanical device that illustrates the relative positions and motions of the planets and moons in the solar system in heliocentric model."@en .

<http://astrothesaurus.org/uat/433> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2022-06-21T18:56:51.250Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Early astronomical instrumentation"@en ;
	skos:broader <http://astrothesaurus.org/uat/799> ;
	skos:prefLabel "Early astronomical instruments"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1187> , <http://astrothesaurus.org/uat/1230> , <http://astrothesaurus.org/uat/1303> , <http://astrothesaurus.org/uat/1638> , <http://astrothesaurus.org/uat/1841> , <http://astrothesaurus.org/uat/67> , <http://astrothesaurus.org/uat/93> , <http://astrothesaurus.org/uat/2334> , <http://astrothesaurus.org/uat/2335> ;
	skos:related <http://astrothesaurus.org/uat/64> .

<http://astrothesaurus.org/uat/1188> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:13:31.122Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/337> ;
	skos:prefLabel "Oscillating universe"@en ;
	skos:definition "A cosmological model in which the Universe is closed and undergoes a series of oscillations, each beginning with a big bang and ending with a big crunch."@en .

<http://astrothesaurus.org/uat/1260> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2022-06-21T17:44:41.762Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Planets"@en , "Planets (Solar system)"@en ;
	skos:broader <http://astrothesaurus.org/uat/1528> ;
	skos:prefLabel "Solar system planets"@en ;
	skos:narrower <http://astrothesaurus.org/uat/797> , <http://astrothesaurus.org/uat/1191> ;
	skos:related <http://astrothesaurus.org/uat/1089> , <http://astrothesaurus.org/uat/498> .

<http://astrothesaurus.org/uat/1426> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T17:10:03.385Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1191> ;
	skos:prefLabel "Saturn"@en ;
	skos:related <http://astrothesaurus.org/uat/1427> ;
	skos:definition "The sixth planet from the Sun and the second largest with an equatorial diameter of 120,536 km orbiting at an average distance of 1,429,400,000 km (9.54 astronomical units) from Sun. With an eccentricity of 0.05555, its distance from the Sun ranges from 1.35 billion km (9.024 AU) at its perihelion to 1.509 billion km (10.086 AU) at its aphelion. Its average orbital speed being 9.69 km/s, it takes Saturn 29.457 Earth years (or 10,759 Earth days) to complete a single revolution around the Sun. However, Saturn also takes just over 10 and a half hours (10 hours 33 minutes) to rotate once on its axis. This means that a single year on Saturn lasts about 24,491 Saturnian solar days. Saturn has a mass of 5.6836 x 1026 kg (95.159 Earth masses) and a mean density of 0.687 g cm^(-3). Like Jupiter, Saturn is about 75% hydrogen and 25% helium with traces of water, methane, and ammonia, similar to the composition of the primordial Solar Nebula from which the solar system was formed. The temperature on Saturn is ~ -185 °C. Like Jupiter, Saturn has a solid core of iron-nickel and rock (silicon and oxygen compounds). The core has an estimated mass of 9-22 Earth Masses and a diameter of about 25,000 km (about 2 Earth diameter). The core is enveloped by a liquid metallic hydrogen layer and a molecular hydrogen layer. Saturn's interior is hot (12,000 K at the core). The planet radiates more energy into space than it receives from the Sun. Most of the extra energy is generated by the Kelvin-Helmholtz mechanism as in Jupiter. Saturn has 62 known satellites. Saturn's ring. On 1 July 2004 NASA/ESA's Cassini-Huygens became the first to orbit Saturn, beginning a 13 year mission that revealed many secrets and surprises about Saturn and its system of rings and moons."@en .

<http://astrothesaurus.org/uat/1751> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:51:37.124Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1191> ;
	skos:prefLabel "Uranus"@en ;
	skos:related <http://astrothesaurus.org/uat/1750> ;
	skos:definition "The seventh planet from the Sun and the third largest, discovered by William Herschel in 1781. It has a diameter about 51,100 km, four times that of the Earth, and a mass 14.5 times Earth's mass. Uranus orbits the Sun at a distance over 19 times the Earth-Sun distance. Although it takes about 84 years for Uranus to make a revolution, it completes a fast rotation in only 17 and a half hours. Unlike the other planets, its axis of rotation lies mostly in the plane of the Solar System. Uranus is internally less active than the other giant planets, which added to its larger distance from the Sun, makes it colder. It has a dense atmosphere made of mostly molecular hydrogen (83 percent) and helium (15 percent), with two percent methane and traces of acetylene and other hydrocarbons. The planet's greenish-blue color is due to light scattering as in Earth's sky and the absorption of red light by its small amount of atmospheric methane. Uranus has a ring system and 27 known satellites."@en .

<http://astrothesaurus.org/uat/873> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-24T17:10:30.752Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1191> ;
	skos:prefLabel "Jupiter"@en ;
	skos:related <http://astrothesaurus.org/uat/872> ;
	skos:definition "The largest planet in the Solar System and the fifth from the Sun, lying at a mean distance of about 5.2 astronomical units from the Sun. Jupiter is a gas giant, mostly hydrogen and helium, with a mass of 1.898 x 10^27 kg, or about 0.001 solar masses, or 318 times Earth masses. It is more than twice as massive as all the other solar system planets combined. Jupiter's diameter measures 11 times that of Earth. Its rotation period, 9.93 hours (Jupiter/Earth ratio = 0.41), is the shortest of all the solar system planets. Its orbital period is 11.857 Earth years. Jupiter has an extensive family of satellites (79 known) and a faint ring system; Jupiter's ring. Jupiter probably has a core of rocky material amounting to something like 10 to 15 Earth masses. Above the core lies the main bulk of the planet in the form of liquid metallic hydrogen. This exotic form of the most common of elements is possible only at pressures about 3 million bars, as is the case in the interior of Jupiter (and Saturn). Under the extreme pressure found deep inside Jupiter, the electrons are released from the hydrogen molecules and are free to move about the interior. This causes hydrogen to behave as a metal; it becomes conducting for both heat and electricity."@en .

<http://astrothesaurus.org/uat/1194> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-21T14:29:24.723Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/437> ;
	skos:prefLabel "Ozone layer"@en ;
	skos:definition "An atmospheric layer that contains a high proportion of oxygen that exists as ozone. It acts as a filtering mechanism against incoming ultraviolet radiation. It is located between the troposphere and the stratosphere, around 15 to 20 kilometers above the Earth's surface."@en .

<http://astrothesaurus.org/uat/80> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-12-16T19:22:40.625Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/1684> ;
	skos:prefLabel "Astrometry"@en ;
	skos:narrower <http://astrothesaurus.org/uat/999> , <http://astrothesaurus.org/uat/1197> , <http://astrothesaurus.org/uat/1677> , <http://astrothesaurus.org/uat/85> , <http://astrothesaurus.org/uat/395> , <http://astrothesaurus.org/uat/1217> , <http://astrothesaurus.org/uat/1218> , <http://astrothesaurus.org/uat/1219> , <http://astrothesaurus.org/uat/1220> , <http://astrothesaurus.org/uat/1227> , <http://astrothesaurus.org/uat/1564> , <http://astrothesaurus.org/uat/1724> , <http://astrothesaurus.org/uat/131> , <http://astrothesaurus.org/uat/1332> , <http://astrothesaurus.org/uat/1337> , <http://astrothesaurus.org/uat/1553> , <http://astrothesaurus.org/uat/182> , <http://astrothesaurus.org/uat/1385> , <http://astrothesaurus.org/uat/1394> , <http://astrothesaurus.org/uat/1463> , <http://astrothesaurus.org/uat/1481> , <http://astrothesaurus.org/uat/1541> , <http://astrothesaurus.org/uat/1595> , <http://astrothesaurus.org/uat/82> , <http://astrothesaurus.org/uat/173> , <http://astrothesaurus.org/uat/1807> , <http://astrothesaurus.org/uat/449> , <http://astrothesaurus.org/uat/466> , <http://astrothesaurus.org/uat/555> , <http://astrothesaurus.org/uat/2328> ;
	skos:related <http://astrothesaurus.org/uat/2130> ;
	skos:definition "The precise measurement of the positions and motions of astronomical objects."@en .

<http://astrothesaurus.org/uat/1231> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:31:29.247Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1197> ;
	skos:prefLabel "Photometric parallax"@en ;
	skos:definition "A method of deriving the distance of a star using its apparent magnitude and the absolute magnitude inferred from its spectral type."@en .

<http://astrothesaurus.org/uat/1439> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T20:43:23.516Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1197> ;
	skos:prefLabel "Secular parallax"@en ;
	skos:definition "The angle subtended at a star by a baseline that is the distance the Sun moves in a given interval of time with respect to the local standard of rest (4.09 AU per year)."@en .

<http://astrothesaurus.org/uat/1573> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:13:41.766Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1197> ;
	skos:prefLabel "Statistical parallax"@en ;
	skos:definition "The mean parallax of a group of stars that are all at approximately the same distance, as determined from their radial velocities and proper motions."@en .

<http://astrothesaurus.org/uat/1618> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:19:14.992Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1197> ;
	skos:prefLabel "Stellar parallax"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1516> ;
	skos:related <http://astrothesaurus.org/uat/1595> ;
	skos:definition "The apparent difference in the position of a celestial object as seen by an observer from two widely separated locations. The parallax of an object can be used to derive its distance. The relationship between the parallax angle  p (measured in seconds of arc) and the distance d (measured in astronomical units) is given by d = 206,264 / p. For a parallax angle p = 1'', the distance to the star would correspond to 206,264 AU. By convention, the distance unit parsec is defined to be equivalent to 206,264 AU. Therefore, the parallax relation takes the much simpler form: d (in pc) = 1/p (in seconds of arc). The first star whose parallax was measured was 61 Cygni (Bessel, 1838)."@en .

<http://astrothesaurus.org/uat/1713> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-19T16:41:14.798Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1197> ;
	skos:prefLabel "Trigonometric parallax"@en ;
	skos:definition "The parallax of a nearby star (less than 300 light-years) against the background of more distant stars resulting from the motion of the Earth in its orbit around the Sun."@en .

<http://astrothesaurus.org/uat/396> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:14:11.057Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Geocentric parallax"@en ;
	skos:broader <http://astrothesaurus.org/uat/1197> ;
	skos:prefLabel "Diurnal parallax"@en ;
	skos:narrower <http://astrothesaurus.org/uat/748> ;
	skos:definition "The apparent difference between the position of a celestial object measured from the Earth's surface and the position that would be recorded by a hypothetical observer at the center of the Earth."@en .

<http://astrothesaurus.org/uat/42> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-04T22:22:58.071Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Heliocentric parallax"@en ;
	skos:broader <http://astrothesaurus.org/uat/1197> ;
	skos:prefLabel "Annual parallax"@en ;
	skos:definition "The difference in position of a star as seen from the Earth and Sun, i.e. the angle subtended at a star by the mean  radius of the Earth's orbit around the Sun. Same as heliocentric parallax.  Because the Earth revolves around the Sun, we observe the sky from a constantly moving position in space. Therefore, we should expect to see an annual effect, in which the positions of nearby objects appear to oscillate back and forth in response to our motion around the Sun. This does in fact happen, but the distances to even the nearest stars are so great that we need to make careful observations with a telescope to detect it. The annual parallax of the nearest star, Proxima Centauri, is 0.762 arcsec, which is too small for our acuity of vision."@en .

<http://astrothesaurus.org/uat/423> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:27:55.554Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1197> ;
	skos:prefLabel "Dynamical parallax"@en ;
	skos:definition "A method for deriving the distance to a binary star. The angular diameter of the orbit of the stars around each other and their apparent brightness are observed. By applying Kepler's laws and the mass-luminosity relation, the distance of the binary star can be calculated."@en .

<http://astrothesaurus.org/uat/888> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1197> ;
	skos:prefLabel "Kinematic parallax"@en .

<http://astrothesaurus.org/uat/534> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T21:11:37.940Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "FOV"@en , "Field of vision"@en , "Fields of view"@en , "Fields of vision"@en ;
	skos:broader <http://astrothesaurus.org/uat/1684> ;
	skos:prefLabel "Field of view"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1198> , <http://astrothesaurus.org/uat/163> , <http://astrothesaurus.org/uat/737> ;
	skos:related <http://astrothesaurus.org/uat/2103> , <http://astrothesaurus.org/uat/533> ;
	skos:scopeNote "At telescope' foci"@en ;
	skos:definition "The entire angular expanse of the sky viewed by an optical instrument."@en .

<http://astrothesaurus.org/uat/1199> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:20:27.603Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:altLabel "Parallax second"@en ;
	skos:broader <http://astrothesaurus.org/uat/395> ;
	skos:prefLabel "Parsec"@en ;
	skos:definition "A basic unit of astronomical distances, corresponding to a trigonometric parallax of one second of arc. In other words, it is the distance at which one astronomical unit (the mean radius of the Earth's orbit) subtends an angle of 1 arcsecond. 1 pc = 3.2616 light-years = 206,265 astronomical units = 30.857 x 10^12 km."@en .

<http://astrothesaurus.org/uat/395> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/80> ;
	skos:prefLabel "Distance measure"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1199> , <http://astrothesaurus.org/uat/919> , <http://astrothesaurus.org/uat/95> .

<http://astrothesaurus.org/uat/12> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T17:45:49.551Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/364> ;
	skos:prefLabel "Accelerating universe"@en ;
	skos:definition "The deduction based on the observation that the most distant Type Ia supernovae are fainter than that expected from their redshifts in a matter-only dominated expanding Universe. The faintness is attributed to larger distances resulting from an accelerating Universe driven by presence of a new component with strongly negative pressure. This component that makes the Universe accelerate is named dark energy."@en .

<http://astrothesaurus.org/uat/364> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T19:53:17.374Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Q-parameter"@en ;
	skos:broader <http://astrothesaurus.org/uat/339> ;
	skos:prefLabel "Deceleration parameter"@en ;
	skos:narrower <http://astrothesaurus.org/uat/12> ;
	skos:definition "A parameter designating the rate at which the expansion of the Universe would slow down owing to the braking gravitational effect of the matter content of the Universe."@en .

<http://astrothesaurus.org/uat/120> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/1686> ;
	skos:prefLabel "Australites"@en .

<http://astrothesaurus.org/uat/1200> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-03T20:19:12.641Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/442> ;
	skos:prefLabel "Partial eclipses"@en ;
	skos:definition "An eclipse that is not total."@en .

<http://astrothesaurus.org/uat/442> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-10-30T19:19:12.185Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/1677> ;
	skos:prefLabel "Eclipses"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1200> , <http://astrothesaurus.org/uat/1205> , <http://astrothesaurus.org/uat/133> , <http://astrothesaurus.org/uat/951> , <http://astrothesaurus.org/uat/1489> , <http://astrothesaurus.org/uat/1704> , <http://astrothesaurus.org/uat/1744> , <http://astrothesaurus.org/uat/1846> , <http://astrothesaurus.org/uat/43> , <http://astrothesaurus.org/uat/49> ;
	skos:definition "The passage of the shadow of a celestial body over the surface of another. The maximum number of solar and lunar visible eclipses occurring annually is seven; the minimum number is two, both being solar. Solar eclipses take place when the new Moon is close to an orbital node and on the same longitude with the Sun. At that moment either the umbra, antumbra, or the penumbra touches the Earth's surface. For an observer located in the umbra the eclipse is total, while for one placed in the antumbra it is annular. Annular eclipses occur around lunar apogee. An observer situated in the penumbra sees only a partial eclipse. A total or annular eclipse can be seen from a band with a width of 270 km at the most, around which, the much larger partiality zone extends. The Moon's shadow crosses the Earth from west to east at about 3,200 km/h. During total eclipses the Sun's disk is entirely covered and the solar corona can be seen. A solar eclipse can last up to 3h (between the first and the fourth contacts). Totality has a theoretical maximum duration of 7m 31s, but it is usually shorter. A lunar eclipse can be seen from any place on Earth where the Moon is above the horizon; it occurs when the full Moon passes through the central dark shadow of the Earth. The Earth's shadow is much wider than the Moon and this is why the lunar eclipses can last up to four hours (between the first and the fourth contact)."@en .

<http://astrothesaurus.org/uat/1203> a rdfs:Resource , skos:Concept ;
	skos:broader <http://astrothesaurus.org/uat/645> ;
	skos:prefLabel "Penrose limit"@en .

<http://astrothesaurus.org/uat/645> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-09T15:12:12.645Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/641> ;
	skos:prefLabel "Geodesics"@en ;
	skos:narrower <http://astrothesaurus.org/uat/1203> , <http://astrothesaurus.org/uat/663> ;
	skos:definition "The shortest distance between two points in space (or space-time). A geodesic on a sphere is an arc of a great circle. In the theory of general relativity, freely falling bodies follow geodesic paths in space-time."@en .

<http://astrothesaurus.org/uat/1204> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:18:16.725Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Penrose mechanism"@en ;
	skos:broader <http://astrothesaurus.org/uat/159> ;
	skos:prefLabel "Penrose process"@en ;
	skos:definition "A hypothetical means of extracting energy from a rotating black hole. If a particle spirals into the ergosphere of a black hole in a direction counter to the rotation of the black hole, and if the particle then breaks up into two fragments inside the ergosphere, one of the fragments can escape with energy greater than the energy of the original particle."@en .

<http://astrothesaurus.org/uat/159> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2023-02-03T18:28:24.077Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie_Admin> ;
	skos:broader <http://astrothesaurus.org/uat/739> ;
	skos:prefLabel "Black hole physics"@en ;
	skos:narrower <http://astrothesaurus.org/uat/2026> , <http://astrothesaurus.org/uat/145> , <http://astrothesaurus.org/uat/1204> , <http://astrothesaurus.org/uat/1236> , <http://astrothesaurus.org/uat/1320> , <http://astrothesaurus.org/uat/160> , <http://astrothesaurus.org/uat/161> , <http://astrothesaurus.org/uat/1706> , <http://astrothesaurus.org/uat/472> , <http://astrothesaurus.org/uat/479> , <http://astrothesaurus.org/uat/703> , <http://astrothesaurus.org/uat/892> ;
	skos:related <http://astrothesaurus.org/uat/162> .

<http://astrothesaurus.org/uat/1205> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:19:56.818Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Penumbras"@en ;
	skos:broader <http://astrothesaurus.org/uat/442> ;
	skos:prefLabel "Penumbra"@en ;
	skos:definition "The portion of a shadow in which light from an extended source is partially but not completely cut off by an intervening body; the area of partial shadow surrounding the umbra.  The lighter part of a shadow during an eclipse. An observer standing in the penumbra of a Solar eclipse will see a partial eclipse."@en .

<http://astrothesaurus.org/uat/1207> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:20:38.854Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:altLabel "Pericenter"@en ;
	skos:broader <http://astrothesaurus.org/uat/63> ;
	skos:prefLabel "Periapsis"@en ;
	skos:definition "The point in an orbit of a body where it is closest to its primary; opposite of apoapsis."@en .

<http://astrothesaurus.org/uat/1208> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:23:32.595Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/63> ;
	skos:prefLabel "Periastron"@en ;
	skos:definition "In a binary system, the point in the orbit where a component is nearest the other component; opposite of apastron."@en .

<http://astrothesaurus.org/uat/1209> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:24:09.933Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
	skos:broader <http://astrothesaurus.org/uat/63> ;
	skos:prefLabel "Perigee"@en ;
	skos:definition "The point in the orbit of a body revolving around the Earth at which it is nearest to the Earth; opposite of apogee."@en .

<http://astrothesaurus.org/uat/121> a rdfs:Resource , skos:Concept ;
	skos:altLabel "Robotic telescope"@en ;
	skos:broader <http://astrothesaurus.org/uat/1689> ;
	skos:prefLabel "Automated telescopes"@en ;
	skos:narrower <http://astrothesaurus.org/uat/122> .

<http://astrothesaurus.org/uat/122> a rdfs:Resource , skos:Concept ;
