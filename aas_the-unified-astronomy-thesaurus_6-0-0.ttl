<http://astrothesaurus.org/uat/1234> a rdfs:Resource , skos:Concept ;
	dcterms:modified "2020-11-17T19:32:27.638Z"^^xsd:dateTime ;
	dcterms:contributor <http://editor.vocabs.ands.org.au/user/AAS_Frey.Katie> ;
